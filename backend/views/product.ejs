<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= product ? product.name : 'Product' %> — Shri Brand
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Crimson+Text:wght@400;600;700&family=Poppins:wght@300;400;500;600;700&display=swap"
    rel="stylesheet" />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@300;400;600&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
   <link rel="stylesheet" href="/css/mediaquery.css" />
   <link rel="stylesheet" href="/css/products.css" />

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary-maroon: #7d1f1f;
      --primary-gold: #fdb913;
      --dark-maroon: #5a1616;
      --text-primary: #2c2c2c;
      --text-secondary: #6b6b6b;
      --sale-color: #dc3545;
      --bg-color: #faf7f2;
      --border-color: #e8e3d8;
      --hover-bg: #fff8e7;
      --card-bg: #ffffff;
      --whatsapp-green: #25d366;
      --whatsapp-dark: #128c7e;
    }
    .site-header .container{
      padding: 0px 16px;
      max-width:1200px;
    margin: 0 auto;
    }
    #desktop-nav,#desktop-nav .nav-link {
      visibility: hidden;
    }

    body {
      font-family: "Poppins", -apple-system, BlinkMacSystemFont, sans-serif;
      color: var(--text-primary);
      background-color: var(--bg-color);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 40px 20px;
    }
    #card {
      width: 35%;
      height: calc(100vh - 60px);
      /* ✅ IMPORTANT */
      background-color: #ffffff;
      position: fixed;
      top: 60px;
      right: 0;
      z-index: 20;

      display: flex;
      flex-direction: column;

      overflow-y: auto;
      /* ✅ use auto, not scroll */
      transform: translateX(100%);
      transition: transform 0.5s ease-in-out;
    }

    /* Mobile: Cart takes 100% width */
    @media (max-width: 767px) {
      #card {
        width: 100%;
        top: 50px;
        height: calc(100vh - 50px);
      }
    }

    /* When active */
    #card.active {
      transform: translateX(0);
    }

    /* Prevent page scroll when card is open */
    body.no-scroll {
      overflow: hidden;
    }

    /* Cart Backdrop Overlay */
    .cart-backdrop {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.3);
      backdrop-filter: blur(0px);
      -webkit-backdrop-filter: blur(0px);
      z-index: 15;
      opacity: 0;
      visibility: hidden;
      transition:
        opacity 0.3s ease,
        visibility 0.3s ease;
    }

    .cart-backdrop.active {
      opacity: 1;
      visibility: visible;
    }

    /* ── Cart item: nested structure (.product-details > .selecteditems) ── */
    .product-details {
      text-align: center;
      font-size: 16px;
      width: 100% !important;
    }

    .product-details .selecteditems {
      display: flex;
      justify-content: start;
      align-items: center;
      text-align: left;
      padding: 10px 10px;
      border-bottom: 1px solid #818181;
      width: 100%;
    }

    .product-details .selecteditems .card-img img {
      width: 120px;
      height: 120px;
      -o-object-fit: cover;
      object-fit: cover;
      -o-object-position: center;
      object-position: center;
      border-radius: 10%;
    }

    .product-details .selecteditems .product-d {
      margin-left: 10px;
    }

    .product-details .selecteditems .product-d p,
    .product-details .selecteditems .product-d span {
      font-size: 12px !important;
      color: #666666;
    }

    .product-details .selecteditems .product-d .btns {
      display: flex;
      justify-content: flex-start;
      align-items: center;
      width: 100%;
      border: none;
      border-radius: 3px;
    }

    /* ── Cart item: flat structure (.selecteditems.product-details on same div) ── */
    .selecteditems.product-details {
      display: flex;
      justify-content: flex-start;
      align-items: center;
      text-align: left;
      padding: 10px 10px;
      border-bottom: 1px solid #818181;
      width: 100%;
    }

    .selecteditems.product-details .card-img img {
      width: 120px !important;
      height: 120px !important;
      -o-object-fit: cover;
      object-fit: cover;
      -o-object-position: center;
      object-position: center;
      border-radius: 10% !important;
    }

    .selecteditems.product-details .product-d {
      margin-left: 10px;
      flex: 1;
    }

    .selecteditems.product-details .product-d h3 {
      font-size: 18px;
      font-weight: 700;
      margin: 0 0 4px 0;
    }

    .selecteditems.product-details .product-d p,
    .selecteditems.product-details .product-d span {
      font-size: 12px !important;
      color: #666666;
    }

    .selecteditems.product-details .product-d .btns {
      display: flex;
      justify-content: flex-start;
      align-items: center;
      width: 100%;
      border: none;
      border-radius: 3px;
    }

    .btns {
      display: flex;
      align-items: center;
      gap: 15px;
      margin-top: 10px;
    }

    /* Quantity box */
    .qty-control {
      display: flex;
      align-items: center;
      border: 1px solid #aaa;
      border-radius: 6px;
      overflow: hidden;
    }

    /* + and - buttons */
    .qty-btn {
      width: 32px;
      height: 32px;
      border: none;
      background: #f5f5f5;
      font-size: 20px;
      font-weight: bold;
      cursor: pointer;
    }

    .qty-btn:hover {
      background: #ddd;
    }

    /* Quantity number */
    .qty-value {
      width: 40px;
      text-align: center;
      font-size: 16px;
      font-weight: bold;
      background: #fff;
    }

    /* Remove button */
    .remove {
      background: #ffb703;
      border: none;
      padding: 9px 30px;
      font-weight: bold;
      cursor: pointer;
      border-radius: 4px;
    }

    /* ── LAYOUT ── */
    .product-section {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      margin-top: 20px;
    }

    /* ── GALLERY ── */
    .gallery-container {
      position: sticky;
      top: 40px;
      height: fit-content;
    }

    .main-image-container {
      position: relative;
      width: 100%;
      aspect-ratio: 1 / 1;
      overflow: hidden;
      border-radius: 12px;
      background: var(--card-bg);
      margin-bottom: 20px;
      box-shadow: 0 6px 24px rgba(125, 31, 31, 0.12);
      border: 1px solid var(--border-color);
    }

    .main-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      cursor: zoom-in;
      transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
    }

    .main-image:hover {
      transform: scale(1.05);
    }

    .thumbnail-container {
      display: flex;
      gap: 12px;
      overflow-x: auto;
      padding: 10px 0;
      scrollbar-width: thin;
      scrollbar-color: var(--primary-gold) transparent;
    }

    .thumbnail-container::-webkit-scrollbar {
      height: 6px;
    }

    .thumbnail-container::-webkit-scrollbar-track {
      background: transparent;
    }

    .thumbnail-container::-webkit-scrollbar-thumb {
      background: var(--primary-gold);
      border-radius: 3px;
    }

    .thumbnail {
      flex-shrink: 0;
      width: 100px;
      height: 100px;
      border-radius: 6px;
      overflow: hidden;
      cursor: pointer;
      border: 2px solid transparent;
      transition: all 0.3s ease;
      background: #fff;
    }

    .thumbnail:hover {
      border-color: var(--primary-gold);
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(253, 185, 19, 0.3);
    }

    .thumbnail.active {
      border-color: var(--primary-maroon);
      box-shadow: 0 4px 12px rgba(125, 31, 31, 0.35);
    }

    .thumbnail img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .nav-arrows {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 100%;
      display: flex;
      justify-content: space-between;
      padding: 0 20px;
      pointer-events: none;
    }

    .arrow {
      pointer-events: all;
      width: 45px;
      height: 45px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.95);
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.15);
      transition: all 0.3s ease;
      opacity: 0;
    }

    .main-image-container:hover .arrow {
      opacity: 1;
    }

    .arrow:hover {
      background: var(--primary-maroon);
      transform: scale(1.1);
    }

    .arrow:hover svg {
      stroke: white;
    }

    .arrow svg {
      stroke: var(--text-primary);
      transition: stroke 0.3s ease;
    }

    /* ── PRODUCT INFO ── */
    .product-info {
      padding: 20px 0;
    }

    .badge-container {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }

    .product-category {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--primary-gold);
      padding: 6px 16px;
      background: rgba(253, 185, 19, 0.1);
      border-radius: 20px;
    }

    .fragrance-badge {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--primary-maroon);
      padding: 6px 16px;
      background: rgba(125, 31, 31, 0.08);
      border: 1px solid rgba(125, 31, 31, 0.2);
      border-radius: 20px;
    }

    .product-title {
      font-family: "Playfair Display", serif;
      font-size: 44px;
      font-weight: 600;
      line-height: 1.2;
      color: var(--primary-maroon);
      margin-bottom: 16px;
    }

    .vendor {
      font-size: 14px;
      color: var(--text-secondary);
      margin-bottom: 24px;
    }

    .sku-stock-container {
      display: flex;
      gap: 16px;
      align-items: center;
      margin-bottom: 24px;
      flex-wrap: wrap;
    }

    .sku-text {
      font-size: 13px;
      color: var(--text-secondary);
    }

    .sku-text strong {
      color: var(--text-primary);
      font-weight: 600;
    }

    .stock-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      font-weight: 600;
      padding: 4px 12px;
      border-radius: 20px;
    }

    .stock-badge.in-stock {
      color: #28a745;
      background: rgba(40, 167, 69, 0.1);
    }

    .stock-badge.low-stock {
      color: #ffc107;
      background: rgba(255, 193, 7, 0.1);
    }

    .stock-badge.out-of-stock {
      color: #dc3545;
      background: rgba(220, 53, 69, 0.1);
    }

    .price-container {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 32px;
    }

    .price-regular {
      font-size: 16px;
      color: var(--text-secondary);
      text-decoration: line-through;
    }

    .price-sale {
      font-size: 28px;
      font-weight: 700;
      color: var(--text-primary);
    }

    .sale-badge {
      background: var(--sale-color);
      color: white;
      padding: 5px 14px;
      border-radius: 5px;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .product-description {
      font-size: 15px;
      color: var(--text-secondary);
      line-height: 1.8;
      margin-bottom: 32px;
      padding-bottom: 32px;
      border-bottom: 1px solid var(--border-color);
    }

    /* ── PACK SELECTOR ── */
    .pack-section {
      margin-bottom: 28px;
    }

    .pack-label {
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 12px;
      display: block;
      color: var(--text-primary);
    }

    .pack-options {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .pack-pill {
      padding: 10px 22px;
      border: 2px solid var(--border-color);
      border-radius: 30px;
      background: var(--card-bg);
      cursor: pointer;
      font-size: 14px;
      font-weight: 500;
      color: var(--text-secondary);
      transition: all 0.3s ease;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2px;
      min-width: 90px;
    }

    .pack-pill:hover {
      border-color: var(--primary-gold);
      color: var(--text-primary);
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(253, 185, 19, 0.2);
    }

    .pack-pill.active {
      border-color: var(--primary-maroon);
      background: rgba(125, 31, 31, 0.06);
      color: var(--primary-maroon);
      font-weight: 600;
      box-shadow: 0 4px 12px rgba(125, 31, 31, 0.15);
    }

    .pack-pill .pack-weight {
      font-size: 15px;
      font-weight: 600;
    }

    .pack-pill .pack-price {
      font-size: 12px;
      color: var(--text-secondary);
    }

    .pack-pill.active .pack-price {
      color: var(--primary-maroon);
    }

    .pack-pill.out-of-stock {
      opacity: 0.4;
      cursor: not-allowed;
      text-decoration: line-through;
    }

    /* ── QUANTITY ── */
    .quantity-section {
      margin-bottom: 24px;
    }

    .quantity-label {
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 12px;
      display: block;
    }

    .quantity-selector {
      display: inline-flex;
      align-items: center;
      border: 1px solid var(--border-color);
      border-radius: 8px;
      overflow: hidden;
      background: var(--card-bg);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .quantity-btn {
      width: 45px;
      height: 45px;
      border: none;
      background: var(--card-bg);
      cursor: pointer;
      font-size: 20px;
      color: var(--primary-maroon);
      transition: all 0.2s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
    }

    .quantity-btn:hover {
      background: var(--hover-bg);
    }

    .quantity-btn:active {
      transform: scale(0.95);
    }

    .quantity-input {
      width: 60px;
      height: 45px;
      border: none;
      border-left: 1px solid var(--border-color);
      border-right: 1px solid var(--border-color);
      text-align: center;
      font-size: 16px;
      font-weight: 500;
    }

    .quantity-input:focus {
      outline: none;
    }

    .quantity-input:disabled {
      background: #f5f5f5;
      color: #aaa;
    }

    /* ── BUTTONS ── */
    .button-group {
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin-bottom: 32px;
    }

    .btn {
      padding: 16px 32px;
      font-size: 14px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      position: relative;
      overflow: hidden;
    }

    .btn-primary {
      background: var(--card-bg);
      color: var(--primary-maroon);
      border: 2px solid var(--primary-maroon);
    }

    .btn-primary:hover:not(:disabled) {
      background: var(--primary-maroon);
      color: white;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(125, 31, 31, 0.25);
    }

    .btn-whatsapp {
      background: var(--whatsapp-green);
      color: #fff;
      border: 2px solid var(--whatsapp-green);
      font-weight: 700;
    }

    .btn-whatsapp:hover:not(:disabled) {
      background: var(--whatsapp-dark);
      border-color: var(--whatsapp-dark);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(37, 211, 102, 0.35);
    }

    .btn-whatsapp .wa-icon {
      font-size: 18px;
      flex-shrink: 0;
    }

    .btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none !important;
      box-shadow: none !important;
      filter: grayscale(30%);
    }

    /* ── USED FOR TAGS ── */
    .used-for-section {
      margin: 32px 0;
      padding: 24px;
      background: var(--card-bg);
      border-radius: 12px;
      border: 1px solid var(--border-color);
    }

    .section-title {
      font-family: "Crimson Text", serif;
      font-size: 20px;
      font-weight: 600;
      color: var(--primary-maroon);
      margin-bottom: 16px;
    }

    .tags-container {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .tag {
      display: inline-block;
      padding: 8px 18px;
      background: linear-gradient(135deg, rgba(253, 185, 19, 0.1), rgba(125, 31, 31, 0.05));
      border: 1px solid var(--border-color);
      border-radius: 25px;
      font-size: 14px;
      color: var(--text-primary);
      font-weight: 500;
      transition: all 0.3s ease;
    }

    .tag:hover {
      background: linear-gradient(135deg, rgba(253, 185, 19, 0.2), rgba(125, 31, 31, 0.1));
      border-color: var(--primary-gold);
      transform: translateY(-2px);
    }

    /* ── DETAILS TABLE ── */
    .product-details-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 32px;
      background: var(--card-bg);
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }

    .product-details-table tr {
      border-bottom: 1px solid var(--border-color);
    }

    .product-details-table tr:last-child {
      border-bottom: none;
    }

    .product-details-table td {
      padding: 18px 20px;
      font-size: 14px;
    }

    .product-details-table td:first-child {
      font-weight: 600;
      color: var(--primary-maroon);
      width: 40%;
    }

    .product-details-table td:last-child {
      color: var(--text-secondary);
    }

    /* ── TOAST ── */
    .toast-notification {
      position: fixed;
      top: 20px;
      right: 20px;
      padding: 14px 24px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      color: white;
      z-index: 9999;
      display: flex;
      align-items: center;
      gap: 10px;
      box-shadow: 0 6px 24px rgba(0, 0, 0, 0.15);
      animation: slideInRight 0.3s ease-out;
      max-width: 320px;
    }

    .toast-notification.success {
      background: #28a745;
    }

    .toast-notification.error {
      background: #dc3545;
    }

    .toast-notification.warning {
      background: #ffc107;
      color: #333;
    }

    @keyframes slideInRight {
      from {
        transform: translateX(400px);
        opacity: 0;
      }
      to {
        transform: translateX(0);
        opacity: 1;
      }
    }

    @keyframes ripple {
      to {
        transform: scale(4);
        opacity: 0;
      }
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      .product-section {
        gap: 40px;
      }
      .product-title {
        font-size: 36px;
      }
    }

    @media (max-width: 768px) {
      
      .product-section {
        grid-template-columns: 1fr;
        gap: 32px;
      }
      .gallery-container {
        position: relative;
        top: 0;
      }
      .product-title {
        font-size: 32px;
      }
      .price-sale {
        font-size: 24px;
      }
      .thumbnail {
        width: 80px;
        height: 80px;
      }
      .nav-arrows {
        padding: 0 10px;
      }
      .arrow {
        width: 40px;
        height: 40px;
      }
      .sku-stock-container {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
      }
      .used-for-section {
        padding: 20px;
      }
      .section-title {
        font-size: 18px;
      }
    }

    @media (max-width: 480px) {
      .product-title {
        font-size: 28px;
      }
      .thumbnail {
        width: 70px;
        height: 70px;
      }
      .button-group {
        gap: 12px;
      }
      .btn {
        padding: 14px 24px;
        font-size: 14px;
      }
      .product-details-table td {
        padding: 12px 16px;
        font-size: 13px;
      }
    }
  </style>
</head>

<body>
  <div class="cart-backdrop" id="cart-backdrop" onclick="toggleCard()"></div>

    <div id="card">
      <!-- Cart Header -->
      <div class="cart-header">
        <div class="cart-header-left" onclick="toggleCard()">
          <i class="fas fa-arrow-left"></i>
          <h3>Your Cart</h3>
        </div>
        <span id="cart-item-count">0 items</span>
      </div>

      <!-- Cart Items Container - Dynamically populated -->
      <div id="cart-items-container">
        <!-- Cart items will be loaded dynamically via JavaScript -->
        <div class="empty-cart-message" id="empty-cart-msg">
          <i class="fas fa-shopping-cart" style="font-size: 48px; color: #ccc; margin-bottom: 10px"></i>
          <p>Your cart is empty</p>
          <small>Add products to see them here</small>
        </div>
      </div>

      <!-- Cart Summary -->
      <div class="cart-summary" id="cart-summary">
        <div class="summary-row total">
          <span>Total:</span>
          <span id="cart-total">₹0</span>
        </div>
        <button class="checkout-btn" id="checkout-btn">
          Proceed to Checkout
        </button>
      </div>
    </div>
  <header class="site-header" role="banner">
    <nav class="container" aria-label="Main navigation">
      <div class="nav-row">
        <div class="logo-wrap">
          <img id="site-logo" class="logo" src="/assets/images/logo/Logo.png" alt="Shri Brand" />
          <!-- <h2 style="color: #7f0403; margin-left: .5rem;">Shri Brand</h2> -->
        </div>

       

        <!-- Right side icons group (Profile, Cart, Hamburger) -->
        <div class="nav-right-group">
          <div class="user-info">
            <!-- <a class="user-btn profile-btn" href="/profile" role="menuitem" title="Profile">
              <i class="fas fa-user"></i>
              <span>Profile</span>
            </a> -->
            <a class="user-btn cart-btn" role="menuitem" onclick="toggleCard()">
              <i class="fas fa-shopping-cart"></i>
              <span class="cart-count" id="nav-cart-count">0</span>
            </a>
          </div>

          
        </div>
      </div>

      <!-- Mobile Overlay -->
      <div class="mobile-overlay" id="mobile-overlay"></div>

     
    </nav>
  </header>

  <% if (!product) { %>
    <div class="container" style="text-align:center; padding:100px 20px;">
      <h1 style="font-family:'Playfair Display',serif; color:var(--primary-maroon); font-size:48px;">Product Not Found</h1>
      <p style="color:var(--text-secondary); margin:20px 0;">The product you're looking for doesn't exist or has been removed.</p>
      <a href="/" style="display:inline-block; padding:14px 32px; background:var(--primary-gold); color:var(--text-primary); border-radius:8px; text-decoration:none; font-weight:600;">Back to Home</a>
    </div>

  <% } else { %>

    <div class="container">
      <div class="product-section">

        <!-- IMAGE GALLERY -->
        <div class="gallery-container">
          <div class="main-image-container">
            <img id="mainImage" class="main-image" src="<%= product.mainImage %>" alt="<%= product.name %>" />
            <div class="nav-arrows">
              <button class="arrow" id="prevBtn">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path d="M15 18L9 12L15 6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </button>
              <button class="arrow" id="nextBtn">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path d="M9 18L15 12L9 6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </button>
            </div>
          </div>

          <div class="thumbnail-container">
            <div class="thumbnail active" data-index="0">
              <img src="<%= product.mainImage %>" alt="Main View" />
            </div>
            <% if (product.images && product.images.length > 0) { %>
              <% product.images.forEach(function(img, idx) { %>
                <div class="thumbnail" data-index="<%= idx + 1 %>">
                  <img src="<%= img %>" alt="View <%= idx + 2 %>" />
                </div>
              <% }); %>
            <% } %>
          </div>
        </div>

        <!-- PRODUCT INFO -->
        <div class="product-info">

          <div class="badge-container">
            <span class="product-category">Premium Long Dhoop</span>
            <span class="fragrance-badge">
              <%= product.fragranceCategory.charAt(0).toUpperCase() + product.fragranceCategory.slice(1) %>
            </span>
          </div>

          <h1 class="product-title"><%= product.name %></h1>
          <div class="vendor">Shri Brand</div>

          <%
            // Sort packs by weightValue ascending
            var sortedPacks = (product.packs || []).slice().sort(function(a, b) {
              return a.weightValue - b.weightValue;
            });

            // Default pack: first in-stock pack, or first pack if all out of stock
            var defaultPack = null;
            for (var pi = 0; pi < sortedPacks.length; pi++) {
              if (sortedPacks[pi].stock > 0) {
                defaultPack = sortedPacks[pi];
                break;
              }
            }
            if (!defaultPack && sortedPacks.length > 0) {
              defaultPack = sortedPacks[0];
            }

            var totalStock = sortedPacks.reduce(function(sum, p) { return sum + (p.stock || 0); }, 0);
            var lowStockThreshold = defaultPack ? (defaultPack.lowStockThreshold || 10) : 10;
          %>

          <div class="sku-stock-container">
            <span class="sku-text">SKU: <strong><%= product.sku %></strong></span>
            <% if (totalStock === 0) { %>
              <span class="stock-badge out-of-stock">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                  <circle cx="6" cy="6" r="6" fill="currentColor" />
                </svg>
                Out of Stock
              </span>
            <% } else if (defaultPack && defaultPack.stock <= lowStockThreshold) { %>
              <span class="stock-badge low-stock">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                  <circle cx="6" cy="6" r="6" fill="currentColor" />
                </svg>
                Low Stock (<%= defaultPack.stock %> left)
              </span>
            <% } else if (defaultPack) { %>
              <span class="stock-badge in-stock">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                  <circle cx="6" cy="6" r="6" fill="currentColor" />
                </svg>
                In Stock (<%= defaultPack.stock %>)
              </span>
            <% } %>
          </div>

          <div class="price-container" id="priceContainer">
            <% if (defaultPack) { %>
              <% if (defaultPack.originalPrice && defaultPack.originalPrice > defaultPack.price) { %>
                <span class="price-regular" id="originalPriceEl">Rs. <%= defaultPack.originalPrice.toFixed(2) %></span>
              <% } else { %>
                <span class="price-regular" id="originalPriceEl" style="display:none;"></span>
              <% } %>
              <span class="price-sale" id="salePriceEl">Rs. <%= defaultPack.price.toFixed(2) %></span>
              <% if (defaultPack.originalPrice && defaultPack.originalPrice > defaultPack.price) { %>
                <span class="sale-badge" id="saleBadgeEl">Sale</span>
              <% } else { %>
                <span class="sale-badge" id="saleBadgeEl" style="display:none;">Sale</span>
              <% } %>
            <% } %>
          </div>

          <div class="product-description">
            <%= product.fullDescription %>
          </div>

          <% if (sortedPacks.length > 1) { %>
            <div class="pack-section">
              <label class="pack-label">Select Pack</label>
              <div class="pack-options" id="packOptions">
                <% sortedPacks.forEach(function(pack, idx) { %>
                  <div
                    class="pack-pill <%= idx === 0 ? 'active' : '' %> <%= pack.stock <= 0 ? 'out-of-stock' : '' %>"
                    data-pack-index="<%= idx %>"
                    data-weight="<%= pack.weight %>"
                    data-weight-value="<%= pack.weightValue %>"
                    data-price="<%= pack.price %>"
                    data-original-price="<%= pack.originalPrice || 0 %>"
                    data-discount="<%= pack.discountPercentage || 0 %>"
                    data-stock="<%= pack.stock %>"
                    data-stick-count="<%= pack.stickCount || 0 %>"
                    data-low-stock-threshold="<%= pack.lowStockThreshold || 10 %>">
                    <span class="pack-weight"><%= pack.weight %></span>
                    <span class="pack-price">₹<%= pack.price %></span>
                  </div>
                <% }); %>
              </div>
            </div>
          <% } %>

          <div class="quantity-section">
            <label class="quantity-label">Quantity</label>
            <div class="quantity-selector">
              <button class="quantity-btn" id="decreaseBtn" <%= totalStock === 0 ? 'disabled' : '' %>>−</button>
              <input
                type="number"
                class="quantity-input"
                id="quantityInput"
                value="1"
                min="1"
                max="<%= defaultPack ? Math.min(defaultPack.stock, 2000) : 0 %>"
                <%= totalStock === 0 ? 'disabled' : '' %>
              />
              <button class="quantity-btn" id="increaseBtn" <%= totalStock === 0 ? 'disabled' : '' %>>+</button>
            </div>
          </div>

          <div class="button-group">
            <!-- Add to Cart -->
            <button
              class="btn btn-primary"
              id="addToCartBtn"
              data-product-id="<%= product._id %>"
              data-pack-weight="<%= defaultPack ? defaultPack.weight : '' %>"
              <%= totalStock === 0 ? 'disabled title="Currently out of stock"' : '' %>>
              <% if (totalStock === 0) { %>
                <i class="fas fa-ban"></i> Out of Stock
              <% } else { %>
                <i class="fas fa-shopping-cart"></i> Add to Cart
              <% } %>
            </button>

            <!-- WhatsApp -->
            <button
              class="btn btn-whatsapp"
              id="whatsappBtn"
              data-product-name="<%= product.name %>"
              data-product-price="<%= defaultPack ? defaultPack.price : 0 %>"
              data-product-sku="<%= product.sku %>"
              data-product-slug="<%= product.slug %>"
              data-pack-weight="<%= defaultPack ? defaultPack.weight : '' %>"
              <%= totalStock === 0 ? 'disabled title="Currently out of stock"' : '' %>>
              <% if (totalStock === 0) { %>
                <i class="fas fa-ban wa-icon"></i> Out of Stock
              <% } else { %>
                <i class="fab fa-whatsapp wa-icon"></i> Buy via WhatsApp
              <% } %>
            </button>
          </div>

          <% if (product.usedFor && product.usedFor.length > 0) { %>
            <div class="used-for-section">
              <h3 class="section-title">Perfect For</h3>
              <div class="tags-container">
                <% product.usedFor.forEach(function(use) { %>
                  <span class="tag"><%= use.charAt(0).toUpperCase() + use.slice(1) %></span>
                <% }); %>
              </div>
            </div>
          <% } %>

          <table class="product-details-table">
            <% if (sortedPacks.length > 0) { %>
              <tr>
                <td>Available Packs</td>
                <td><%= sortedPacks.map(function(p) { return p.weight; }).join(', ') %></td>
              </tr>
            <% } %>
            <% if (product.burnTime) { %>
              <tr>
                <td>Burning Time</td>
                <td><%= product.burnTime %></td>
              </tr>
            <% } %>
            <% if (defaultPack && defaultPack.stickCount) { %>
              <tr>
                <td>Stick Count</td>
                <td id="stickCountCell"><%= defaultPack.stickCount %> sticks</td>
              </tr>
            <% } %>
            <tr>
              <td>Fragrance Type</td>
              <td><%= product.fragranceCategory.charAt(0).toUpperCase() + product.fragranceCategory.slice(1) %></td>
            </tr>
            <tr>
              <td>Product Type</td>
              <td><%= product.productType.charAt(0).toUpperCase() + product.productType.slice(1) %></td>
            </tr>
          </table>

        </div><!-- /.product-info -->
      </div><!-- /.product-section -->
    </div><!-- /.container -->

  <% } %>

  <% if (product) { %>
  <script>
    (function () {
      'use strict'; // ✅ FIXED: removed extra space before 'use'

      var CART_API = '/api/v1/cart';
      var WA_NUMBER = '919361917574';
      var LOW_STOCK_THRESHOLD = <%= defaultPack ? (defaultPack.lowStockThreshold || 10) : 10 %>;

      // ── Pack Data ──
      var selectedPackWeight = '<%= defaultPack ? defaultPack.weight : "" %>';

      // ── Pack Selector ──
      var packPills = document.querySelectorAll('.pack-pill');

      function selectPack(pill) {
        if (pill.classList.contains('out-of-stock')) return;

        packPills.forEach(function (p) {
          p.classList.remove('active');
        });
        pill.classList.add('active');

        var weight           = pill.dataset.weight;
        var price            = parseFloat(pill.dataset.price);
        var originalPrice    = parseFloat(pill.dataset.originalPrice);
        var stock            = parseInt(pill.dataset.stock);
        var packStickCount   = parseInt(pill.dataset.stickCount) || 0;
        var packThreshold    = parseInt(pill.dataset.lowStockThreshold) || 10;

        selectedPackWeight   = weight;
        LOW_STOCK_THRESHOLD  = packThreshold;

        // Update stick count in details table
        var stickCountCell = document.getElementById('stickCountCell');
        if (stickCountCell) {
          stickCountCell.textContent = packStickCount > 0 ? packStickCount + ' sticks' : '—';
        }

        // Update price display
        var salePriceEl    = document.getElementById('salePriceEl');
        var originalPriceEl = document.getElementById('originalPriceEl');
        var saleBadgeEl    = document.getElementById('saleBadgeEl');

        if (salePriceEl) {
          salePriceEl.textContent = 'Rs. ' + price.toFixed(2);
        }

        if (originalPrice && originalPrice > price) {
          if (originalPriceEl) {
            originalPriceEl.textContent = 'Rs. ' + originalPrice.toFixed(2);
            originalPriceEl.style.display = '';
          }
          if (saleBadgeEl) {
            saleBadgeEl.style.display = '';
          }
        } else {
          if (originalPriceEl) {
            originalPriceEl.style.display = 'none';
          }
          if (saleBadgeEl) {
            saleBadgeEl.style.display = 'none';
          }
        }

        // Update stock badge
        var skuStockContainer = document.querySelector('.sku-stock-container');
        var oldBadge = skuStockContainer ? skuStockContainer.querySelector('.stock-badge') : null;

        if (oldBadge) {
          var svgCircle = '<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><circle cx="6" cy="6" r="6" fill="currentColor"/></svg>';
          if (stock === 0) {
            oldBadge.className = 'stock-badge out-of-stock';
            oldBadge.innerHTML = svgCircle + ' Out of Stock';
          } else if (stock <= LOW_STOCK_THRESHOLD) {
            oldBadge.className = 'stock-badge low-stock';
            oldBadge.innerHTML = svgCircle + ' Low Stock (' + stock + ' left)';
          } else {
            oldBadge.className = 'stock-badge in-stock';
            oldBadge.innerHTML = svgCircle + ' In Stock (' + stock + ')';
          }
        }

        // Update quantity controls
        var quantityInput  = document.getElementById('quantityInput');
        var decreaseBtn    = document.getElementById('decreaseBtn');
        var increaseBtn    = document.getElementById('increaseBtn');
        var addToCartBtn   = document.getElementById('addToCartBtn');
        var whatsappBtn    = document.getElementById('whatsappBtn');

        if (stock === 0) {
          quantityInput.disabled = true;
          quantityInput.value    = 0;
          decreaseBtn.disabled   = true;
          increaseBtn.disabled   = true;

          if (addToCartBtn) {
            addToCartBtn.disabled = true;
            addToCartBtn.innerHTML = '<i class="fas fa-ban"></i> Out of Stock';
          }
          if (whatsappBtn) {
            whatsappBtn.disabled = true;
            whatsappBtn.innerHTML = '<i class="fas fa-ban wa-icon"></i> Out of Stock';
          }
        } else {
          quantityInput.disabled = false;
          quantityInput.max      = Math.min(stock, 2000);

          if (parseInt(quantityInput.value) > stock) quantityInput.value = stock;
          if (parseInt(quantityInput.value) < 1)     quantityInput.value = 1;

          decreaseBtn.disabled = false;
          increaseBtn.disabled = false;

          if (addToCartBtn) {
            addToCartBtn.disabled = false;
            addToCartBtn.innerHTML = '<i class="fas fa-shopping-cart"></i> Add to Cart';
          }
          if (whatsappBtn) {
            whatsappBtn.disabled = false;
            whatsappBtn.innerHTML = '<i class="fab fa-whatsapp wa-icon"></i> Buy via WhatsApp';
          }
        }

        // Update data attributes on buttons
        if (addToCartBtn) {
          addToCartBtn.dataset.packWeight = weight;
        }
        if (whatsappBtn) {
          whatsappBtn.dataset.productPrice = price;
          whatsappBtn.dataset.packWeight   = weight;
        }
      }

      // Attach click listeners to pack pills
      packPills.forEach(function (pill) {
        pill.addEventListener('click', function () {
          selectPack(pill);
        });
      });

      // Auto-select first in-stock pack pill on load
      (function () {
        var found = false;
        packPills.forEach(function (pill) {
          if (!found && !pill.classList.contains('out-of-stock')) {
            pill.classList.add('active');
            selectPack(pill);
            found = true;
          } else {
            pill.classList.remove('active');
          }
        });
        if (!found && packPills.length > 0) {
          packPills[0].classList.add('active');
        }
      })();

      // ── Image Gallery ──
      var allImages = ['<%= product.mainImage %>'<% if (product.images && product.images.length > 0) { product.images.forEach(function(img) { %>, '<%= img %>'<% }); } %>];

      var currentIndex = 0;
      var mainImage    = document.getElementById('mainImage');
      var thumbnails   = document.querySelectorAll('.thumbnail');
      var prevBtn      = document.getElementById('prevBtn');
      var nextBtn      = document.getElementById('nextBtn');

      function updateImage(index) {
        currentIndex = index;
        mainImage.style.opacity = '0';
        setTimeout(function () {
          mainImage.src           = allImages[index];
          mainImage.style.opacity = '1';
        }, 200);
        thumbnails.forEach(function (t, i) {
          t.classList.toggle('active', i === index);
        });
      }

      thumbnails.forEach(function (t, i) {
        t.addEventListener('click', function () { updateImage(i); });
      });

      prevBtn.addEventListener('click', function () {
        updateImage((currentIndex - 1 + allImages.length) % allImages.length);
      });

      nextBtn.addEventListener('click', function () {
        updateImage((currentIndex + 1) % allImages.length);
      });

      document.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowLeft')  prevBtn.click();
        if (e.key === 'ArrowRight') nextBtn.click();
      });

      var touchStartX = 0;
      mainImage.addEventListener('touchstart', function (e) {
        touchStartX = e.changedTouches[0].screenX;
      });
      mainImage.addEventListener('touchend', function (e) {
        var dx = e.changedTouches[0].screenX - touchStartX;
        if (dx < -50) nextBtn.click();
        if (dx >  50) prevBtn.click();
      });

      // ── Quantity ──
      var quantityInput = document.getElementById('quantityInput');
      var decreaseBtn   = document.getElementById('decreaseBtn');
      var increaseBtn   = document.getElementById('increaseBtn');

      decreaseBtn.addEventListener('click', function () {
        var v = parseInt(quantityInput.value);
        if (v > 1) quantityInput.value = v - 1;
      });

      increaseBtn.addEventListener('click', function () {
        var v   = parseInt(quantityInput.value);
        var max = parseInt(quantityInput.max) || 2000;
        if (v < max) quantityInput.value = v + 1;
      });

      quantityInput.addEventListener('change', function () {
        var max = parseInt(quantityInput.max) || 2000;
        var v   = parseInt(quantityInput.value);
        if (isNaN(v) || v < 1) v = 1;
        if (v > max) v = max;
        quantityInput.value = v;
      });

      // ── Toast ──
      function showToast(message, type) {
        type = type || 'success';
        var existing = document.querySelector('.toast-notification');
        if (existing) existing.remove();

        var icons = {
          success: 'fa-check-circle',
          error:   'fa-exclamation-circle',
          warning: 'fa-exclamation-triangle'
        };

        var toast = document.createElement('div');
        toast.className = 'toast-notification ' + type;
        toast.innerHTML = '<i class="fas ' + icons[type] + '"></i> ' + message;
        document.body.appendChild(toast);

        setTimeout(function () {
          toast.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
          toast.style.opacity    = '0';
          toast.style.transform  = 'translateX(400px)';
          setTimeout(function () { toast.remove(); }, 300);
        }, 3500);
      }

      // ── Add to Cart ──
      var addToCartBtn = document.getElementById('addToCartBtn');

      if (addToCartBtn && !addToCartBtn.disabled) {
        addToCartBtn.addEventListener('click', async function () {
          var productId  = addToCartBtn.dataset.productId;
          var packWeight = addToCartBtn.dataset.packWeight || selectedPackWeight;
          var quantity   = parseInt(quantityInput.value);
          var original   = addToCartBtn.innerHTML;

          addToCartBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Adding...';
          addToCartBtn.disabled  = true;

          try {
            var res  = await fetch(CART_API, {
              method:      'POST',
              headers:     { 'Content-Type': 'application/json' },
              credentials: 'include',
              body:        JSON.stringify({ productId: productId, quantity: quantity, packWeight: packWeight })
            });
            var data = await res.json();

            if (res.status === 401) {
              showToast('Please login to add items to your cart!', 'warning');
              setTimeout(function () { window.location.href = '/auth'; }, 1500);
              return;
            }

            if (!res.ok) {
              showToast(data.message || 'Could not add to cart.', 'error');
              return;
            }

            showToast(quantity + ' x ' + packWeight + ' added to cart!', 'success');

            // Update cart badge and sidebar instantly (functions from product.js)
            if (typeof updateCartCount === 'function' && data.data && data.data.cart) {
              updateCartCount(data.data.cart.summary.totalItems);
            }
            if (typeof renderCartSidebar === 'function' && data.data && data.data.cart) {
              renderCartSidebar(data.data.cart);
            }

            // Auto-open cart sidebar (function from product.js)
            if (typeof openCartSidebar === 'function') {
              openCartSidebar();
            } else {
              var card = document.getElementById('card');
              if (card && !card.classList.contains('active')) {
                if (typeof toggleCard === 'function') toggleCard();
              }
            }
          } catch (err) {
            showToast('Network error. Please try again.', 'error');
          } finally {
            addToCartBtn.innerHTML = original;
            addToCartBtn.disabled  = false;
          }
        });
      }

      // ── WhatsApp ──
      var whatsappBtn = document.getElementById('whatsappBtn');

      if (whatsappBtn && !whatsappBtn.disabled) {
        whatsappBtn.addEventListener('click', function () {
          var productName  = whatsappBtn.dataset.productName;
          var productPrice = whatsappBtn.dataset.productPrice;
          var productSku   = whatsappBtn.dataset.productSku;
          var productSlug  = whatsappBtn.dataset.productSlug;
          var packWeight   = whatsappBtn.dataset.packWeight || selectedPackWeight;
          var quantity     = parseInt(quantityInput.value);
          var pageUrl      = window.location.origin + '/product/' + productSlug;

          var message =
            'Hello Shri Brand! 🙏\n\n' +
            'I\'m interested in purchasing the following product:\n\n' +
            '*Product:* ' + productName  + '\n' +
            '*Pack:* '    + packWeight   + '\n' +
            '*SKU:* '     + productSku   + '\n' +
            '*Price:* ₹'  + productPrice + '\n' +
            '*Quantity:* '+ quantity     + '\n\n' +
            '*Product Link:* ' + pageUrl + '\n\n' +
            'Kindly confirm availability and assist me with the order. Thank you!';

          window.open(
            'https://wa.me/' + WA_NUMBER + '?text=' + encodeURIComponent(message),
            '_blank',
            'noopener,noreferrer'
          );
        });
      }

      // ── Ripple effect (only on enabled buttons) ──
      document.querySelectorAll('.btn:not([disabled])').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
          var ripple = document.createElement('span');
          var rect   = this.getBoundingClientRect();
          var size   = Math.max(rect.width, rect.height);

          ripple.style.cssText =
            'position:absolute;' +
            'width:'  + size + 'px;' +
            'height:' + size + 'px;' +
            'border-radius:50%;' +
            'background:rgba(255,255,255,0.4);' +
            'pointer-events:none;' +
            'transform:scale(0);' +
            'left:' + (e.clientX - rect.left - size / 2) + 'px;' +
            'top:'  + (e.clientY - rect.top  - size / 2) + 'px;' +
            'animation:ripple 0.6s ease-out;';

          this.appendChild(ripple);
          setTimeout(function () { ripple.remove(); }, 600);
        });
      });

    })(); // ✅ IIFE closes correctly
  </script>
  <% } %>
  <script src="/js/product.js"></script>
  <script>
     function toggleCard() {
      const card = document.getElementById("card");
      const backdrop = document.getElementById("cart-backdrop");
      const menuCheckbox = document.getElementById("menu-toggle");

      // Close mobile menu if open (uncheck the checkbox)
      if (menuCheckbox && menuCheckbox.checked) {
        menuCheckbox.checked = false;
      }

      document.body.classList.toggle("no-scroll");
      card.classList.toggle("active");
      backdrop.classList.toggle("active");
    }
  </script>
</body>
</html>
