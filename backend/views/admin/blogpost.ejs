    <script>
      /* ═══════════════════════════════════════════════
       API CONFIGURATION & CRUD LAYER
    ═══════════════════════════════════════════════ */
      const API_BASE = "https://shri-brand.onrender.com/api/v1/blogs";
      const FETCH_TIMEOUT = 12000;
      let currentPostId = null;

      class ApiError extends Error {
        constructor(message, status, errors) {
          super(message);
          this.name = "ApiError";
          this.status = status;
          this.errors = errors;
        }
      }

      async function apiFetch(url, options = {}) {
        const controller = new AbortController();
        const timer = setTimeout(() => controller.abort(), FETCH_TIMEOUT);
        options.signal = controller.signal;
        options.headers = {
          "Content-Type": "application/json",
          ...(options.headers || {}),
        };

        try {
          const resp = await fetch(url, options);
          clearTimeout(timer);
          if (resp.status === 204) return { status: "success", data: null };
          const body = await resp.json().catch(() => ({}));
          if (!resp.ok) {
            const msg = body.message || `Server error (${resp.status})`;
            throw new ApiError(msg, resp.status, body.errors);
          }
          return body;
        } catch (err) {
          clearTimeout(timer);
          if (err instanceof ApiError) throw err;
          if (err.name === "AbortError")
            throw new ApiError("Request timed out. Check your connection.", 0);
          if (!navigator.onLine)
            throw new ApiError(
              "You are offline. Check your internet connection.",
              0,
            );
          throw new ApiError("Cannot connect to server. Try again later.", 0);
        }
      }

      /* ── DOM → BLOCKS SERIALIZER ── */
      function serializeContentToBlocks() {
        const area = document.getElementById("contentArea");
        const blocks = [];
        let blockId = 0;
        const nextId = () => "blk-" + ++blockId + "-" + Date.now();

        area.childNodes.forEach((node) => {
          if (node.nodeType === Node.TEXT_NODE) {
            const t = node.textContent.trim();
            if (t) blocks.push({ id: nextId(), type: "paragraph", html: t });
            return;
          }
          if (node.nodeType !== Node.ELEMENT_NODE) return;
          const el = node;
          const tag = el.tagName.toLowerCase();

          // Block wrapper (special blocks: pullquote, idea, warning, info, divider)
          if (el.classList.contains("block-wrapper")) {
            if (el.querySelector(".editor-pullquote")) {
              const txt =
                (el.querySelector(".editor-pullquote-text") || {}).innerText ||
                "";
              blocks.push({
                id: nextId(),
                type: "pullquote",
                text: txt.trim(),
              });
            } else if (el.querySelector(".editor-idea")) {
              const txt =
                (el.querySelector(".editor-idea-content") || {}).innerText ||
                "";
              blocks.push({ id: nextId(), type: "idea", text: txt.trim() });
            } else if (el.querySelector(".editor-warning")) {
              const txt =
                (el.querySelector(".editor-warning-content") || {}).innerText ||
                "";
              blocks.push({ id: nextId(), type: "warning", text: txt.trim() });
            } else if (el.querySelector(".editor-info")) {
              const txt =
                (el.querySelector(".editor-info-content") || {}).innerText ||
                "";
              blocks.push({ id: nextId(), type: "info", text: txt.trim() });
            } else if (el.querySelector(".editor-divider")) {
              const div = el.querySelector(".editor-divider");
              let style = "plain";
              if (div.classList.contains("d-diamond")) style = "diamond";
              else if (div.classList.contains("d-flame")) style = "flame";
              else if (div.classList.contains("d-stars")) style = "stars";
              else if (div.classList.contains("d-wave")) style = "wave";
              blocks.push({ id: nextId(), type: "divider", style });
            }
            return;
          }
          // Image block
          if (el.classList.contains("editor-img-block")) {
            const img = el.querySelector("img");
            const cap = el.querySelector(".img-caption-input");
            if (img && img.src) {
              blocks.push({
                id: nextId(),
                type: "image",
                url: img.src,
                caption: cap ? cap.value : "",
                alt: cap ? cap.value : "",
              });
            }
            return;
          }
          // Headings
          if (["h1", "h2", "h3"].includes(tag)) {
            const level = parseInt(tag[1]);
            blocks.push({
              id: nextId(),
              type: "heading",
              level,
              text: el.innerText.trim(),
            });
            return;
          }
          // Blockquote
          if (tag === "blockquote") {
            blocks.push({
              id: nextId(),
              type: "blockquote",
              text: el.innerText.trim(),
            });
            return;
          }
          // Lists
          if (tag === "ul" || tag === "ol") {
            const items = Array.from(el.querySelectorAll("li"))
              .map((li) => li.innerText.trim())
              .filter(Boolean);
            if (items.length)
              blocks.push({
                id: nextId(),
                type: "list",
                ordered: tag === "ol",
                items,
              });
            return;
          }
          // Code block
          if (tag === "pre") {
            const code = el.querySelector("code");
            const lang = code
              ? code.className.replace("language-", "") || ""
              : "";
            blocks.push({
              id: nextId(),
              type: "code",
              text: (code || el).innerText.trim(),
              language: lang,
            });
            return;
          }
          // Paragraph (default)
          const html = el.innerHTML.trim();
          if (html && html !== "<br>" && html !== "<br/>") {
            blocks.push({ id: nextId(), type: "paragraph", html });
          }
        });
        return blocks;
      }

      /* ── BLOCKS → DOM DESERIALIZER ── */
      function deserializeBlocksToDOM(blocks) {
        const area = document.getElementById("contentArea");
        area.innerHTML = "";
        if (!blocks || !blocks.length) return;

        const del = `<button class="block-delete-btn" title="Delete block" onclick="deleteBlock(this)"><i class="fas fa-times"></i></button>`;

        blocks.forEach((b) => {
          let html = "";
          switch (b.type) {
            case "paragraph":
              html = `<p>${b.html || b.text || ""}</p>`;
              break;
            case "heading":
              html = `<h${b.level || 2}>${b.text || ""}</h${b.level || 2}>`;
              break;
            case "blockquote":
              html = `<blockquote>${b.text || ""}</blockquote>`;
              break;
            case "pullquote":
              html = `<div class="block-wrapper" contenteditable="false">${del}<div class="editor-pullquote"><span class="editor-pullquote-text" contenteditable="true" onkeydown="handleBlockInnerKeydown(event,this)">${b.text || ""}</span></div></div>`;
              break;
            case "idea":
              html = `<div class="block-wrapper" contenteditable="false">${del}<div class="editor-idea"><span class="idea-icon">💡</span><div class="editor-idea-content" contenteditable="true" onkeydown="handleBlockInnerKeydown(event,this)">${b.text || ""}</div></div></div>`;
              break;
            case "warning":
              html = `<div class="block-wrapper" contenteditable="false">${del}<div class="editor-warning"><span class="warn-icon"><i class="fas fa-exclamation-triangle"></i></span><div class="editor-warning-content" contenteditable="true" onkeydown="handleBlockInnerKeydown(event,this)">${b.text || ""}</div></div></div>`;
              break;
            case "info":
              html = `<div class="block-wrapper" contenteditable="false">${del}<div class="editor-info"><span class="info-icon"><i class="fas fa-info-circle"></i></span><div class="editor-info-content" contenteditable="true" onkeydown="handleBlockInnerKeydown(event,this)">${b.text || ""}</div></div></div>`;
              break;
            case "image":
              html = `<div class="editor-img-block" contenteditable="false"><button class="img-remove" onclick="this.parentElement.remove();updateStats()"><i class="fas fa-times"></i></button><img src="${b.url}" alt="${b.alt || b.caption || ""}"/><input class="img-caption-input" value="${b.caption || ""}" placeholder="Add a caption…"/></div>`;
              break;
            case "divider": {
              const dividers = {
                diamond: `<div class="editor-divider d-diamond"><div class="d-line"></div><span class="d-gem">✦ ◆ ✦</span><div class="d-line"></div></div>`,
                flame: `<div class="editor-divider d-flame"><div class="d-line"></div><span class="d-gem"><i class="fas fa-fire-flame-curved"></i></span><div class="d-line"></div></div>`,
                stars: `<div class="editor-divider d-stars">✦ &nbsp;&nbsp;✦ &nbsp;&nbsp;✦</div>`,
                wave: `<div class="editor-divider d-wave"><svg viewBox="0 0 400 12" xmlns="http://www.w3.org/2000/svg"><path d="M0,6 C50,0 100,12 150,6 C200,0 250,12 300,6 C350,0 380,10 400,6" stroke="#b8860b" stroke-width="1.5" fill="none" opacity=".5"/></svg></div>`,
                plain: `<div class="editor-divider d-plain"></div>`,
              };
              html = `<div class="block-wrapper" contenteditable="false">${del}${dividers[b.style] || dividers.plain}</div>`;
              break;
            }
            case "list": {
              const tag = b.ordered ? "ol" : "ul";
              html = `<${tag}>${(b.items || []).map((it) => `<li>${it}</li>`).join("")}</${tag}>`;
              break;
            }
            case "code":
              html = `<pre><code${b.language ? ` class="language-${b.language}"` : ""}>${b.text || ""}</code></pre>`;
              break;
            default:
              break;
          }
          if (html) area.insertAdjacentHTML("beforeend", html);
        });
        area.insertAdjacentHTML("beforeend", "<p><br/></p>");
      }

      /* ── GATHER FORM DATA ── */
      function gatherPostData() {
        const tags = [];
        document.querySelectorAll("#tagsWrap .tag-chip").forEach((c) => {
          const t = c.textContent.replace(/[×✕]/g, "").trim();
          if (t) tags.push(t);
        });
        const coverPreviewEl = document.getElementById("coverPreview");
        const coverSrc = document.getElementById("coverPreviewImg").src;
        const isCoverVisible =
          coverPreviewEl && coverPreviewEl.style.display !== "none";
        const hasCover =
          isCoverVisible &&
          coverSrc &&
          (coverSrc.startsWith("http") || coverSrc.startsWith("data:"));

        return {
          title: document.getElementById("titleInput").value.trim(),
          subtitle: document.getElementById("subtitleInput").value.trim(),
          blocks: serializeContentToBlocks(),
          category: document.getElementById("categorySelect").value,
          tags,
          author: document.getElementById("authorInput").value.trim(),
          publishDate:
            document.getElementById("publishDate").value || undefined,
          readTime:
            document.getElementById("readTime").value.trim() || undefined,
          coverImage: hasCover ? { url: coverSrc } : undefined,
          settings: {
            isFeatured: document.getElementById("tgl1").checked,
            allowComments: document.getElementById("tgl2").checked,
          },
        };
      }

      /* ── CLIENT-SIDE VALIDATION ── */
      function validatePostData(data, forPublish = false) {
        const errors = [];
        if (!data.title) errors.push("Title is required.");
        else if (data.title.length > 300)
          errors.push("Title cannot exceed 300 characters.");
        if (data.subtitle && data.subtitle.length > 500)
          errors.push("Subtitle cannot exceed 500 characters.");
        if (data.tags && data.tags.length > 20)
          errors.push("Maximum 20 tags allowed.");
        if (forPublish) {
          if (!data.blocks || data.blocks.length === 0)
            errors.push("Add some content before publishing.");
          if (!data.coverImage || !data.coverImage.url)
            errors.push("Cover image is required to publish.");
          if (!data.subtitle) errors.push("Subtitle is required to publish.");
          if (!data.category) errors.push("Category is required to publish.");
        }
        // Validate image blocks
        (data.blocks || []).forEach((b, i) => {
          if (b.type === "image" && (!b.url || !b.url.trim()))
            errors.push(`Block ${i + 1} (image): URL is missing.`);
          if (b.type === "heading" && (!b.text || !b.text.trim()))
            errors.push(`Block ${i + 1} (heading): text is empty.`);
        });
        return errors;
      }

      /* ── INTERNAL SAVE (used by publish only) ── */
      async function _savePost(data) {
        let result;
        if (currentPostId) {
          result = await apiFetch(`${API_BASE}/${currentPostId}`, {
            method: "PATCH",
            body: JSON.stringify(data),
          });
        } else {
          result = await apiFetch(API_BASE, {
            method: "POST",
            body: JSON.stringify(data),
          });
          if (result.data && result.data.post) {
            currentPostId = result.data.post._id;
          }
        }
        return result;
      }

      /* ── LOAD EXISTING POST ── */
      async function loadPost(idOrSlug) {
        try {
          setStatus("loading");
          let url = `${API_BASE}/${idOrSlug}`;
          // Try slug if it doesn't look like a MongoDB ObjectId
          if (!/^[a-f\d]{24}$/i.test(idOrSlug))
            url = `${API_BASE}/slug/${idOrSlug}`;
          const data = await apiFetch(url);
          if (!data || !data.data || !data.data.post)
            throw new ApiError("Post not found", 404);
          const p = data.data.post;
          currentPostId = p._id;

          document.getElementById("titleInput").value = p.title || "";
          document.getElementById("subtitleInput").value = p.subtitle || "";
          autoResize(document.getElementById("titleInput"));
          autoResize(document.getElementById("subtitleInput"));
          document.getElementById("categorySelect").value =
            p.category || "traditions";
          document.getElementById("authorInput").value =
            p.author || "Priya Sharma";
          if (p.publishDate)
            document.getElementById("publishDate").value = new Date(
              p.publishDate,
            )
              .toISOString()
              .split("T")[0];
          if (p.readTime) {
            document.getElementById("readTime").value = p.readTime;
            readTimeManuallyEdited = true;
          }
          document.getElementById("tgl1").checked = !!(
            p.settings && p.settings.isFeatured
          );
          document.getElementById("tgl2").checked = p.settings
            ? p.settings.allowComments
            : true;

          // Tags
          const tagsWrap = document.getElementById("tagsWrap");
          tagsWrap.querySelectorAll(".tag-chip").forEach((t) => t.remove());
          (p.tags || []).forEach((t) => addTag(t));

          // Cover
          if (p.coverImage && p.coverImage.url) {
            document.getElementById("coverPreviewImg").src = p.coverImage.url;
            document.getElementById("coverPlaceholder").style.display = "none";
            document.getElementById("coverPreview").style.display = "block";
          }
          // Content
          deserializeBlocksToDOM(p.blocks || []);
          updateStats();
          // Update breadcrumb
          const breadcrumb = document.querySelector(
            ".header-breadcrumb strong",
          );
          if (breadcrumb)
            breadcrumb.textContent =
              p.status === "published" ? "Edit Story" : "Edit Draft";
          history.replaceState(null, "", `?edit=${currentPostId}`);
          setEditMode(true);
          setStatus("saved");
          showToast("Post loaded");
        } catch (err) {
          setStatus("error");
          showToast(
            err.message || "Could not load post",
            "fa-exclamation-triangle",
            true,
          );
        }
      }

      /* ── DELETE POST ── */
      async function deleteCurrentPost() {
        if (!currentPostId) {
          showToast("No post to delete", "fa-info-circle", true);
          return;
        }
        if (!confirm("Permanently delete this post? This cannot be undone."))
          return;
        try {
          setStatus("saving");
          await apiFetch(`${API_BASE}/${currentPostId}`, { method: "DELETE" });
          currentPostId = null;
          confirmReset();
          setEditMode(false);
          history.replaceState(null, "", "blogPost.html");
          showToast("Post deleted successfully");
          refreshPostsDrawer();
          setStatus("saved");
        } catch (err) {
          setStatus("error");
          showToast(
            err.message || "Delete failed",
            "fa-exclamation-triangle",
            true,
          );
        }
      }

      /* ── STATUS INDICATOR ── */
      function setStatus(state) {
        const el =
          document.getElementById("hStatus") ||
          document.querySelector(".h-status");
        if (!el) return;
        const map = {
          saving:
            '<div class="status-dot" style="background:#d4a520;animation:none"></div> Saving…',
          saved: '<div class="status-dot"></div> Draft Saved',
          loading:
            '<div class="status-dot" style="background:#2196f3;animation:none"></div> Loading…',
          error:
            '<div class="status-dot" style="background:#e57373;animation:none"></div> Error',
        };
        el.innerHTML = map[state] || map.saved;
      }

      /* ── SETTINGS DRAWER (mobile) ── */
      function toggleSettingsDrawer() {
        const col = document.querySelector(".settings-col");
        const overlay = document.getElementById("drawerOverlay");
        const fab = document.getElementById("postSettingsFab");
        const isOpen = col.classList.toggle("drawer-open");
        overlay.classList.toggle("show", isOpen);
        fab.classList.toggle("active", isOpen);
        fab.innerHTML = isOpen
          ? '<i class="fas fa-times"></i>'
          : '<i class="fas fa-sliders-h"></i>';
      }
      function closeSettingsDrawer() {
        document.querySelector(".settings-col").classList.remove("drawer-open");
        document.getElementById("drawerOverlay").classList.remove("show");
        const fab = document.getElementById("postSettingsFab");
        fab.classList.remove("active");
        fab.innerHTML = '<i class="fas fa-sliders-h"></i>';
      }

      /* ── RESET ── */
      function openResetModal() {
        document.getElementById("resetModal").classList.add("show");
      }
      function closeResetModal() {
        document.getElementById("resetModal").classList.remove("show");
      }
      function confirmReset() {
        document.getElementById("titleInput").value = "";
        document.getElementById("subtitleInput").value = "";
        document.getElementById("contentArea").innerHTML = "";
        document.getElementById("subtitleInput").style.height = "";
        document.getElementById("titleInput").style.height = "";
        removeCover({ stopPropagation: () => {} });
        document.getElementById("categorySelect").selectedIndex = 0;
        document
          .getElementById("tagsWrap")
          .querySelectorAll(".tag-chip")
          .forEach((t) => t.remove());
        document.getElementById("authorInput").value = "Priya Sharma";
        document.getElementById("publishDate").value = new Date()
          .toISOString()
          .split("T")[0];
        document.getElementById("readTime").value = "";
        readTimeManuallyEdited = false;
        document.getElementById("tgl1").checked = false;
        document.getElementById("tgl2").checked = true;
        closeResetModal();
        updateStats();
        showToast("Page reset successfully", "fa-rotate-left");
      }

      /* ── TABS ── */
      function switchTab(name, btn) {
        document
          .querySelectorAll(".s-tab")
          .forEach((t) => t.classList.remove("active"));
        document
          .querySelectorAll(".s-panel")
          .forEach((p) => p.classList.remove("active"));
        btn.classList.add("active");
        document.getElementById("tab-" + name).classList.add("active");
      }

      /* ── AUTO RESIZE ── */
      function autoResize(el) {
        el.style.height = "auto";
        el.style.height = el.scrollHeight + "px";
      }

      /* ── CARET RANGE ── */
      let savedRange = null;
      function saveCaretRange() {
        const s = window.getSelection();
        if (s && s.rangeCount) savedRange = s.getRangeAt(0).cloneRange();
      }
      function restoreRange() {
        if (!savedRange) return;
        const s = window.getSelection();
        s.removeAllRanges();
        s.addRange(savedRange);
      }

      /* ── FORMATTING ── */
      function fmt(cmd, val) {
        restoreRange();
        document.getElementById("contentArea").focus();
        document.execCommand(cmd, false, val || null);
        savedRange = null;
      }
      function formatBlock(tag) {
        document.getElementById("contentArea").focus();
        document.execCommand("formatBlock", false, tag);
      }
      function wrapCode() {
        restoreRange();
        const sel = window.getSelection();
        if (!sel || sel.isCollapsed) return;
        document.execCommand(
          "insertHTML",
          false,
          `<code>${sel.toString()}</code>`,
        );
      }
      function insertLink() {
        restoreRange();
        const url = prompt("Enter URL:");
        if (url) document.execCommand("createLink", false, url);
      }
      function insertQuoteBlock() {
        document.getElementById("contentArea").focus();
        restoreRange();
        const sel = window.getSelection();
        if (sel && !sel.isCollapsed) {
          document.execCommand("formatBlock", false, "blockquote");
        } else {
          insertHTML(
            "<blockquote>Write your quote here…</blockquote><p><br/></p>",
          );
        }
      }

      /* ── INSERT HTML ── */
      function insertHTML(html) {
        const area = document.getElementById("contentArea");
        area.focus();
        restoreRange();
        if (!document.execCommand("insertHTML", false, html)) {
          const sel = window.getSelection();
          if (!sel.rangeCount) return;
          const r = sel.getRangeAt(0);
          r.deleteContents();
          const div = document.createElement("div");
          div.innerHTML = html;
          const frag = document.createDocumentFragment();
          let node, last;
          while ((node = div.firstChild)) {
            last = frag.appendChild(node);
          }
          r.insertNode(frag);
          if (last) {
            const nr = r.cloneRange();
            nr.setStartAfter(last);
            nr.collapse(true);
            sel.removeAllRanges();
            sel.addRange(nr);
          }
        }
        updateStats();
      }

      /* ── BLOCK DELETE ── */
      function deleteBlock(btn) {
        const w = btn.closest(".block-wrapper");
        if (w) {
          w.remove();
          updateStats();
        }
      }
      function handleBlockInnerKeydown(e, innerEl) {
        if (
          (e.key === "Backspace" || e.key === "Delete") &&
          !(innerEl.innerText || "").trim()
        ) {
          e.preventDefault();
          const w = innerEl.closest(".block-wrapper");
          if (w) {
            w.remove();
            updateStats();
          }
        }
      }

      /* ── SPECIAL BLOCKS ── */
      function insertSpecialBlock(type) {
        saveCaretRange();
        const del = `<button class="block-delete-btn" title="Delete block" onclick="deleteBlock(this)"><i class="fas fa-times"></i></button>`;
        let inner = "";
        if (type === "pullquote")
          inner = `<div class="editor-pullquote"><span class="editor-pullquote-text" contenteditable="true" onkeydown="handleBlockInnerKeydown(event,this)">Write your pull quote here…</span></div>`;
        else if (type === "idea")
          inner = `<div class="editor-idea"><span class="idea-icon">💡</span><div class="editor-idea-content" contenteditable="true" onkeydown="handleBlockInnerKeydown(event,this)"></div></div>`;
        else if (type === "warning")
          inner = `<div class="editor-warning"><span class="warn-icon"><i class="fas fa-exclamation-triangle"></i></span><div class="editor-warning-content" contenteditable="true" onkeydown="handleBlockInnerKeydown(event,this)"></div></div>`;
        else if (type === "info")
          inner = `<div class="editor-info"><span class="info-icon"><i class="fas fa-info-circle"></i></span><div class="editor-info-content" contenteditable="true" onkeydown="handleBlockInnerKeydown(event,this)"></div></div>`;
        insertHTML(
          `<div class="block-wrapper" contenteditable="false">${del}${inner}</div><p><br/></p>`,
        );
      }

      /* ── DECORATIVE DIVIDERS ── */
      function insertDecorDiv(type) {
        saveCaretRange();
        const del = `<button class="block-delete-btn" title="Delete divider" onclick="deleteBlock(this)"><i class="fas fa-times"></i></button>`;
        const dividers = {
          diamond: `<div class="editor-divider d-diamond"><div class="d-line"></div><span class="d-gem">✦ ◆ ✦</span><div class="d-line"></div></div>`,
          flame: `<div class="editor-divider d-flame"><div class="d-line"></div><span class="d-gem"><i class="fas fa-fire-flame-curved"></i></span><div class="d-line"></div></div>`,
          stars: `<div class="editor-divider d-stars">✦ &nbsp;&nbsp;✦ &nbsp;&nbsp;✦</div>`,
          wave: `<div class="editor-divider d-wave"><svg viewBox="0 0 400 12" xmlns="http://www.w3.org/2000/svg"><path d="M0,6 C50,0 100,12 150,6 C200,0 250,12 300,6 C350,0 380,10 400,6" stroke="#b8860b" stroke-width="1.5" fill="none" opacity=".5"/></svg></div>`,
          plain: `<div class="editor-divider d-plain"></div>`,
        };
        insertHTML(
          `<div class="block-wrapper" contenteditable="false">${del}${dividers[type]}</div><p><br/></p>`,
        );
      }

      /* ── SLASH MENU ── */
      let blockMenuOpen = false;
      function handleKeydown(e) {
        if (e.key === "/" && !blockMenuOpen) {
          setTimeout(showBlockMenu, 0);
        }
        if (e.key === "Escape") {
          closeBlockMenu();
          hideFloatToolbar();
        }
      }
      function handleKeyup(e) {
        if (blockMenuOpen && e.key !== "/") closeBlockMenu();
        updateStats();
      }
      function showBlockMenu() {
        const sel = window.getSelection();
        if (!sel || !sel.rangeCount) return;
        const rect = sel.getRangeAt(0).getBoundingClientRect();
        const m = document.getElementById("blockMenu");
        m.style.visibility = "hidden";
        m.style.display = "block";
        const mw = m.offsetWidth,
          mh = m.offsetHeight;
        m.style.display = "";
        m.style.visibility = "";
        const vw = window.innerWidth,
          vh = window.innerHeight,
          GAP = 8;
        let top = rect.bottom + GAP,
          left = rect.left;
        if (top + mh > vh - GAP) top = rect.top - mh - GAP;
        top = Math.max(GAP, top);
        if (left + mw > vw - GAP) left = vw - mw - GAP;
        left = Math.max(GAP, left);
        m.style.top = top + "px";
        m.style.left = left + "px";
        m.classList.add("show");
        blockMenuOpen = true;
      }
      function closeBlockMenu() {
        document.getElementById("blockMenu").classList.remove("show");
        blockMenuOpen = false;
      }
      function insertFromMenu(type) {
        closeBlockMenu();
        document.getElementById("contentArea").focus();
        document.execCommand("delete", false, null);
        const blockTypes = {
          p: () => document.execCommand("formatBlock", false, "p"),
          ul: () => document.execCommand("insertUnorderedList"),
          blockquote: insertQuoteBlock,
          image: openImageModal,
        };
        if (blockTypes[type]) blockTypes[type]();
        else if (["idea", "warning", "info", "pullquote"].includes(type))
          insertSpecialBlock(type);
        else if (["diamond", "flame", "stars", "wave", "plain"].includes(type))
          insertDecorDiv(type);
        else document.execCommand("formatBlock", false, type);
      }
      document.addEventListener("click", (e) => {
        const m = document.getElementById("blockMenu"),
          ca = document.getElementById("contentArea");
        if (m && !m.contains(e.target) && !ca.contains(e.target))
          closeBlockMenu();
      });

      /* ── FLOATING TOOLBAR ── */
      function showFloatToolbar() {
        const sel = window.getSelection();
        if (!sel || sel.isCollapsed || !sel.toString().trim()) {
          hideFloatToolbar();
          return;
        }
        saveCaretRange();
        const rect = sel.getRangeAt(0).getBoundingClientRect();
        const ft = document.getElementById("floatToolbar");
        ft.style.top = rect.top + window.scrollY - 44 + "px";
        ft.style.left = Math.max(0, rect.left + rect.width / 2 - 88) + "px";
        ft.classList.add("show");
      }
      function hideFloatToolbar() {
        document.getElementById("floatToolbar").classList.remove("show");
      }
      document.addEventListener("mousedown", (e) => {
        if (!document.getElementById("floatToolbar").contains(e.target))
          setTimeout(hideFloatToolbar, 100);
      });

      /* ═══════════════════════════════════════════════
       IMAGE UPLOAD — Cloudinary via server endpoints
       All images are uploaded to the server which stores
       them in Cloudinary and returns a permanent HTTPS URL.
       No base64 is ever saved to the database.
    ═══════════════════════════════════════════════ */

      const IMG_UPLOAD_BASE =
        "https://shri-brand.onrender.com/api/v1/blog-images";
      const MAX_IMG_BYTES = 1024 * 1024; // 1 MB hard limit (enforced client + server)
      const ALLOWED_IMG_TYPES = [
        "image/jpeg",
        "image/jpg",
        "image/png",
        "image/webp",
      ];

      /**
       * Validate image before any upload attempt.
       * Returns true if valid, false + shows toast if invalid.
       */
      function validateImageFile(file) {
        if (!file) return false;

        if (!ALLOWED_IMG_TYPES.includes(file.type)) {
          showToast(
            `Invalid type "${file.type}". Use JPG, PNG, or WEBP.`,
            "fa-exclamation-triangle",
            true,
          );
          return false;
        }

        if (file.size > MAX_IMG_BYTES) {
          const kb = Math.round(file.size / 1024);
          showToast(
            `Image too large (${kb} KB). Maximum is 1 024 KB (1 MB).`,
            "fa-exclamation-triangle",
            true,
          );
          return false;
        }

        return true;
      }

      /**
       * Upload a File to the given server endpoint.
       * endpoint: '/cover' | '/content'
       * Returns the Cloudinary URL string on success, null on failure.
       *
       * Shows an uploading toast while in-flight and an error toast on failure.
       */
      async function uploadImageToCloudinary(file, endpoint) {
        const formData = new FormData();
        formData.append("image", file);

        // Optimistic uploading indicator
        const toastKey = `Uploading ${endpoint === "/cover" ? "cover" : "image"}…`;
        showToast(toastKey, "fa-spinner fa-spin", false);

        try {
          const resp = await fetch(`${IMG_UPLOAD_BASE}${endpoint}`, {
            method: "POST",
            body: formData,
            // NOTE: do NOT set Content-Type — browser sets it with the correct boundary
          });

          const body = await resp.json().catch(() => ({}));

          if (!resp.ok) {
            // Server-side validation or Cloudinary error
            const msg = body.message || `Upload failed (${resp.status})`;
            showToast(msg, "fa-exclamation-triangle", true);
            return null;
          }

          return body.data.url; // Cloudinary secure_url
        } catch (err) {
          const msg =
            err.name === "TypeError"
              ? "Cannot reach server. Is it running?"
              : err.message || "Upload failed";
          showToast(msg, "fa-exclamation-triangle", true);
          return null;
        }
      }

      /* ── COVER IMAGE ── */
      function triggerCoverUpload() {
        document.getElementById("coverFileInput").click();
      }

      async function handleCoverFile(e) {
        const f = e.target.files[0];
        if (!f) return;
        if (!validateImageFile(f)) {
          e.target.value = "";
          return;
        }

        // Show a local preview immediately for responsiveness
        const localUrl = URL.createObjectURL(f);
        document.getElementById("coverPreviewImg").src = localUrl;
        document.getElementById("coverPlaceholder").style.display = "none";
        document.getElementById("coverPreview").style.display = "block";

        // Upload to Cloudinary in background
        const cloudUrl = await uploadImageToCloudinary(f, "/cover");
        e.target.value = ""; // always reset input

        if (cloudUrl) {
          // Replace local blob URL with permanent Cloudinary URL
          document.getElementById("coverPreviewImg").src = cloudUrl;
          showToast("Cover image uploaded", "fa-check-circle");
        } else {
          // Upload failed — revert preview so user knows it's not saved
          document.getElementById("coverPreviewImg").src = "";
          document.getElementById("coverPlaceholder").style.display = "flex";
          document.getElementById("coverPreview").style.display = "none";
        }
        URL.revokeObjectURL(localUrl);
      }

      function removeCover(e) {
        e.stopPropagation();
        document.getElementById("coverPreviewImg").src = "";
        document.getElementById("coverPlaceholder").style.display = "flex";
        document.getElementById("coverPreview").style.display = "none";
        document.getElementById("coverFileInput").value = "";
      }

      /* ── IMAGE MODAL ── */
      function openImageModal() {
        saveCaretRange();
        document.getElementById("imgModal").classList.add("show");
      }
      function closeImgModal() {
        document.getElementById("imgModal").classList.remove("show");
        document.getElementById("imgUrlInput").value = "";
        document.getElementById("imgCaptionInput").value = "";
      }
      function switchImgTab(tab, btn) {
        document
          .querySelectorAll(".img-tab")
          .forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        document.getElementById("imgTabUrl").style.display =
          tab === "url" ? "block" : "none";
        document.getElementById("imgTabUpload").style.display =
          tab === "upload" ? "block" : "none";
      }
      function insertImageHtml(src, cap) {
        insertHTML(
          `<div class="editor-img-block" contenteditable="false"><button class="img-remove" onclick="this.parentElement.remove();updateStats()"><i class="fas fa-times"></i></button><img src="${src}" alt="${cap || ""}"/><input class="img-caption-input" value="${cap || ""}" placeholder="Add a caption…"/></div><p><br/></p>`,
        );
        closeImgModal();
      }
      function insertImageFromUrl() {
        const u = document.getElementById("imgUrlInput").value.trim();
        const c = document.getElementById("imgCaptionInput").value.trim();
        if (!u) return;
        insertImageHtml(u, c);
      }
      async function handleInlineFile(e) {
        const f = e.target.files[0];
        if (!f) return;
        if (!validateImageFile(f)) {
          e.target.value = "";
          return;
        }

        const caption = document.getElementById("imgCaptionInput").value.trim();

        // Show a temporary placeholder block while uploading
        const placeholderId = "img-uploading-" + Date.now();
        insertHTML(
          `<div id="${placeholderId}" class="editor-img-block" contenteditable="false" ` +
            `style="background:rgba(184,134,11,0.06);border:1px dashed rgba(184,134,11,0.4);` +
            `display:flex;align-items:center;justify-content:center;min-height:80px;padding:14px;gap:8px;` +
            `font-family:'Jost',sans-serif;font-size:11px;letter-spacing:.08em;color:var(--ink-faint)">` +
            `<i class="fas fa-spinner fa-spin" style="color:var(--accent-gold)"></i> Uploading image…` +
            `</div><p><br/></p>`,
        );
        e.target.value = "";
        closeImgModal();

        const cloudUrl = await uploadImageToCloudinary(f, "/content");

        // Remove the placeholder
        const placeholder = document.getElementById(placeholderId);
        if (placeholder) placeholder.remove();

        if (cloudUrl) {
          // Insert the real image block with the Cloudinary URL
          const del = `<button class="img-remove" onclick="this.parentElement.remove();updateStats()"><i class="fas fa-times"></i></button>`;
          const area = document.getElementById("contentArea");
          area.insertAdjacentHTML(
            "beforeend",
            `<div class="editor-img-block" contenteditable="false">${del}` +
              `<img src="${cloudUrl}" alt="${caption}"/>` +
              `<input class="img-caption-input" value="${caption}" placeholder="Add a caption…"/></div>` +
              `<p><br/></p>`,
          );
          updateStats();
          showToast("Image inserted", "fa-check-circle");
        }
      }

      /* ── TAGS ── */
      function handleTagInput(e) {
        if (e.key === "Enter" || e.key === ",") {
          e.preventDefault();
          const v = e.target.value.trim().replace(",", "");
          if (!v) return;
          addTag(v);
          e.target.value = "";
        }
        if (e.key === "Backspace" && !e.target.value) {
          const chips = document.querySelectorAll(".tag-chip");
          if (chips.length) chips[chips.length - 1].remove();
        }
      }
      function addTag(val) {
        const w = document.getElementById("tagsWrap"),
          inp = document.getElementById("tagInput");
        const c = document.createElement("span");
        c.className = "tag-chip";
        c.innerHTML = `${val} <button onclick="removeTag(this)"><i class="fas fa-times"></i></button>`;
        w.insertBefore(c, inp);
      }
      function removeTag(btn) {
        btn.parentElement.remove();
      }
      function focusTagInput() {
        document.getElementById("tagInput").focus();
      }

      /* ── STATS ── */
      let readTimeManuallyEdited = false;
      function updateStats() {
        const text = document.getElementById("contentArea").innerText || "";
        const words = text.trim() ? text.trim().split(/\s+/).length : 0;
        const mins = Math.max(1, Math.ceil(words / 220));
        const chars = text.length;
        const blocks = document
          .getElementById("contentArea")
          .querySelectorAll(
            "p,h1,h2,h3,blockquote,.editor-idea,.editor-warning,.editor-info,.editor-pullquote",
          ).length;
        const imgs = document
          .getElementById("contentArea")
          .querySelectorAll("img").length;
        document.getElementById("wordCountBar").textContent =
          `${words} words · ~${mins} min read`;
        document.getElementById("charCount").textContent = `${chars} chars`;
        document.getElementById("stat-words").textContent = words;
        document.getElementById("stat-read").textContent = mins + "m";
        document.getElementById("stat-para").textContent = blocks;
        document.getElementById("stat-imgs").textContent = imgs;
        if (!readTimeManuallyEdited)
          document.getElementById("readTime").value = mins + " min read";
      }

      /* ── PREVIEW ── */
      function openPreview() {
        document.getElementById("pvTitle").textContent =
          document.getElementById("titleInput").value || "Untitled Story";
        document.getElementById("pvSubtitle").textContent =
          document.getElementById("subtitleInput").value || "";
        document.getElementById("pvBody").innerHTML =
          document.getElementById("contentArea").innerHTML || "";
        document.getElementById("pvDate").textContent =
          new Date().toLocaleDateString("en-US", {
            month: "long",
            day: "numeric",
            year: "numeric",
          });
        document.getElementById("pvReadTime").textContent =
          document.getElementById("readTime").value || "1 min read";
        const cvr = document.getElementById("pvCover"),
          src = document.getElementById("coverPreviewImg").src;
        if (src && src.length > 20 && !src.endsWith("undefined")) {
          cvr.src = src;
          cvr.style.display = "block";
        } else {
          cvr.style.display = "none";
        }
        const pvTags = document.getElementById("pvTags");
        pvTags.innerHTML = "";
        document.querySelectorAll(".tag-chip").forEach((c) => {
          const t = document.createElement("span");
          t.className = "preview-tag";
          t.textContent = c.textContent.replace(/[×✕]/g, "").trim();
          pvTags.appendChild(t);
        });
        document.getElementById("previewPanel").classList.add("show");
      }
      function closePreview() {
        document.getElementById("previewPanel").classList.remove("show");
      }

      /* ── TOAST ── */
      function showToast(msg, icon, isError) {
        const t = document.getElementById("toast");
        const ic = icon || "fa-check-circle";
        const icColor = isError ? "#e57373" : "var(--accent-gold)";
        t.innerHTML = `<i class="fas ${ic}" style="color:${icColor}"></i> ${msg || "Draft saved"}`;
        t.style.borderTopColor = isError ? "#e57373" : "var(--accent-gold)";
        t.classList.add("show");
        setTimeout(
          () => {
            t.classList.remove("show");
            if (isError)
              setTimeout(() => {
                t.innerHTML = '<i class="fas fa-check-circle"></i> Draft saved';
                t.style.borderTopColor = "";
              }, 300);
          },
          isError ? 4000 : 2300,
        );
      }

      /* ── PUBLISH (API-backed) ── */
      async function handlePublish() {
        const data = gatherPostData();
        const errs = validatePostData(data, true);
        if (errs.length) {
          showToast(errs[0], "fa-exclamation-triangle", true);
          if (!data.title) document.getElementById("titleInput").focus();
          return;
        }
        if (!confirm(`Publish "${data.title}"?`)) return;
        const btn = document.getElementById("headerPublishBtn");
        try {
          btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Publishing…';
          btn.disabled = true;
          await _savePost(data);
          await apiFetch(`${API_BASE}/${currentPostId}/publish`, {
            method: "PATCH",
          });
          btn.innerHTML = '<i class="fas fa-check"></i> Published!';
          btn.style.cssText =
            "background:#3a7a56;border-color:#3a7a56;color:white";
          btn.disabled = false;
          showToast("Post published successfully!", "fa-check-circle");
          refreshPostsDrawer();
          // Notify parent (admin SPA) if inside an iframe
          if (window.parent !== window) {
            window.parent.postMessage({ type: "blog-published" }, "*");
          }
          // Auto-reset editor for a new post after a short delay
          setTimeout(() => {
            btn.innerHTML = '<i class="fas fa-paper-plane"></i> Publish';
            btn.style.cssText = "";
            startNewPost();
          }, 2000);
        } catch (err) {
          showToast(
            err.message || "Publish failed",
            "fa-exclamation-triangle",
            true,
          );
          btn.innerHTML = '<i class="fas fa-paper-plane"></i> Publish';
          btn.style.cssText = "";
          btn.disabled = false;
        }
      }

      /* ── EDIT MODE FLAG ── */
      let isEditMode = false;

      function setEditMode(active) {
        isEditMode = active;
        const btn = document.getElementById("headerPublishBtn");
        if (!btn) return;
        if (active) {
          btn.innerHTML = '<i class="fas fa-cloud-upload-alt"></i> Update';
          btn.title = "Save & update this post";
        } else {
          btn.innerHTML = '<i class="fas fa-paper-plane"></i> Publish';
          btn.title = "";
        }
      }

      function handlePublishOrUpdate() {
        if (isEditMode) {
          handleUpdate();
        } else {
          handlePublish();
        }
      }

      /* ── UPDATE (edit mode — API-backed) ── */
      async function handleUpdate() {
        const data = gatherPostData();
        const errs = validatePostData(data, true);
        if (errs.length) {
          showToast(errs[0], "fa-exclamation-triangle", true);
          if (!data.title) document.getElementById("titleInput").focus();
          return;
        }
        if (!confirm(`Update "${data.title}"?`)) return;
        const btn = document.getElementById("headerPublishBtn");
        try {
          btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Updating…';
          btn.disabled = true;
          await _savePost(data);
          btn.innerHTML = '<i class="fas fa-check"></i> Updated!';
          btn.style.cssText =
            "background:#3a7a56;border-color:#3a7a56;color:white";
          btn.disabled = false;
          showToast("Post updated successfully!", "fa-check-circle");
          refreshPostsDrawer();
          if (window.parent !== window) {
            window.parent.postMessage({ type: "blog-updated" }, "*");
          }
          setTimeout(() => {
            btn.innerHTML = '<i class="fas fa-cloud-upload-alt"></i> Update';
            btn.style.cssText = "";
          }, 2000);
        } catch (err) {
          showToast(
            err.message || "Update failed",
            "fa-exclamation-triangle",
            true,
          );
          btn.innerHTML = '<i class="fas fa-cloud-upload-alt"></i> Update';
          btn.style.cssText = "";
          btn.disabled = false;
        }
      }

      /* ═══════════════════════════════════════════════
       POSTS DRAWER — browse & manage all posts
    ═══════════════════════════════════════════════ */
      let postsDrawerOpen = false;
      let postsListCache = [];
      let postsFilterStatus = "";

      function openPostsDrawer() {
        document.getElementById("postsDrawer").classList.add("open");
        document.getElementById("postsDrawerOverlay").classList.add("show");
        postsDrawerOpen = true;
        fetchPostsList();
      }

      function closePostsDrawer() {
        document.getElementById("postsDrawer").classList.remove("open");
        document.getElementById("postsDrawerOverlay").classList.remove("show");
        postsDrawerOpen = false;
      }

      function refreshPostsDrawer() {
        if (postsDrawerOpen) fetchPostsList();
      }

      async function fetchPostsList() {
        const list = document.getElementById("pdList");
        list.innerHTML =
          '<div class="pd-loading"><i class="fas fa-spinner fa-spin"></i> Loading posts…</div>';
        try {
          let url = `${API_BASE}?limit=50&sortBy=updatedAt&order=desc`;
          if (postsFilterStatus) url += `&status=${postsFilterStatus}`;
          const data = await apiFetch(url);
          if (!data || !data.data || !data.data.posts)
            throw new Error("Invalid response");
          postsListCache = data.data.posts;
          renderPostsList(postsListCache);
        } catch (err) {
          list.innerHTML = `<div class="pd-empty"><i class="fas fa-exclamation-triangle"></i><p>${err.message || "Could not load posts"}</p></div>`;
        }
      }

      function renderPostsList(posts) {
        const list = document.getElementById("pdList");
        const countEl = document.getElementById("pdCount");
        list.innerHTML = "";
        countEl.textContent = `${posts.length} post${posts.length !== 1 ? "s" : ""}`;

        if (!posts.length) {
          list.innerHTML =
            '<div class="pd-empty"><i class="fas fa-feather-alt"></i><p>No posts found. Create your first story!</p></div>';
          return;
        }

        const CAT_MAP = {
          traditions: "Traditions",
          "artisan-crafts": "Artisan Crafts",
          festivals: "Festivals",
          wellness: "Wellness",
          community: "Community",
          "sacred-recipes": "Sacred Recipes",
        };

        posts.forEach((p) => {
          const item = document.createElement("div");
          item.className =
            "pd-item" + (p._id === currentPostId ? " active" : "");
          const statusClass =
            p.status === "published"
              ? "st-published"
              : p.status === "archived"
                ? "st-archived"
                : "st-draft";
          const statusLabel =
            (p.status || "draft").charAt(0).toUpperCase() +
            (p.status || "draft").slice(1);
          const date = p.updatedAt
            ? new Date(p.updatedAt).toLocaleDateString("en-US", {
                month: "short",
                day: "numeric",
                year: "numeric",
              })
            : "";
          const cat = CAT_MAP[p.category] || p.category || "";

          item.innerHTML = `
          <div class="pd-item-title">${p.title || "Untitled"}</div>
          <div class="pd-item-meta">
            <span class="pd-status ${statusClass}">${statusLabel}</span>
            ${cat ? `<span class="pd-item-cat">${cat}</span>` : ""}
            <span class="pd-item-date">${date}</span>
          </div>`;
          item.addEventListener("click", () => {
            closePostsDrawer();
            loadPost(p._id);
          });
          list.appendChild(item);
        });
      }

      function filterPosts(status, btn) {
        postsFilterStatus = status;
        document
          .querySelectorAll(".pd-filter")
          .forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        fetchPostsList();
      }

      function startNewPost() {
        closePostsDrawer();
        currentPostId = null;
        confirmReset();
        setEditMode(false);
        history.replaceState(null, "", "blogPost.html");
        const breadcrumb = document.querySelector(".header-breadcrumb strong");
        if (breadcrumb) breadcrumb.textContent = "New Story";
        showToast("Ready for a new story", "fa-feather-alt");
      }

      /* ── INIT ── */
      document.addEventListener("DOMContentLoaded", () => {
        document.getElementById("publishDate").value = new Date()
          .toISOString()
          .split("T")[0];
        updateStats();
        document.execCommand("defaultParagraphSeparator", false, "p");

        const rt = document.getElementById("readTime");
        rt.addEventListener("input", () => {
          readTimeManuallyEdited = true;
        });
        rt.addEventListener("change", () => {
          if (!rt.value.trim()) readTimeManuallyEdited = false;
        });

        document
          .getElementById("blockToolbar")
          .addEventListener("mousedown", (e) => {
            if (e.target.tagName !== "SELECT") e.preventDefault();
          });
        document
          .getElementById("blockMenu")
          .addEventListener("mousedown", (e) => e.preventDefault());
        document
          .getElementById("floatToolbar")
          .addEventListener("mousedown", (e) => e.preventDefault());

        /* Drag & drop cover */
        const drop = document.getElementById("coverDrop");
        drop.addEventListener("dragover", (e) => {
          e.preventDefault();
          drop.classList.add("drag-over");
        });
        drop.addEventListener("dragleave", () =>
          drop.classList.remove("drag-over"),
        );
        drop.addEventListener("drop", async (e) => {
          e.preventDefault();
          drop.classList.remove("drag-over");
          const f = e.dataTransfer.files[0];
          if (!f || !f.type.startsWith("image/")) return;
          if (!validateImageFile(f)) return;

          // Immediate local preview
          const localUrl = URL.createObjectURL(f);
          document.getElementById("coverPreviewImg").src = localUrl;
          document.getElementById("coverPlaceholder").style.display = "none";
          document.getElementById("coverPreview").style.display = "block";

          const cloudUrl = await uploadImageToCloudinary(f, "/cover");
          if (cloudUrl) {
            document.getElementById("coverPreviewImg").src = cloudUrl;
            showToast("Cover image uploaded", "fa-check-circle");
          } else {
            document.getElementById("coverPreviewImg").src = "";
            document.getElementById("coverPlaceholder").style.display = "flex";
            document.getElementById("coverPreview").style.display = "none";
          }
          URL.revokeObjectURL(localUrl);
        });

        /* Keyboard shortcut: Escape to close drawer */
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && postsDrawerOpen) closePostsDrawer();
        });

        /* Load existing post if ?edit= param present */
        const params = new URLSearchParams(window.location.search);
        const editId = params.get("edit");
        if (editId) {
          setEditMode(true);
          loadPost(editId);
        }

        /* Show close button when inside iframe (admin SPA modal) */
        if (window.parent !== window) {
          const closeBtn = document.getElementById("blogEditorCloseBtn");
          if (closeBtn) closeBtn.style.display = "";
          const backWrap = document.getElementById("hDropdownBackWrap");
          if (backWrap) backWrap.style.display = "";
        }
      });

      /* ── MOBILE HEADER MENU ── */
      function toggleHeaderMenu() {
        const btn = document.getElementById("hMobileMenuBtn");
        const dropdown = document.getElementById("hDropdown");
        if (!btn || !dropdown) return;
        const isOpen = dropdown.classList.toggle("open");
        btn.classList.toggle("open", isOpen);
      }

      function closeHeaderMenu() {
        const btn = document.getElementById("hMobileMenuBtn");
        const dropdown = document.getElementById("hDropdown");
        if (btn) btn.classList.remove("open");
        if (dropdown) dropdown.classList.remove("open");
      }

      /* Close dropdown when clicking outside */
      document.addEventListener("click", function (e) {
        const btn = document.getElementById("hMobileMenuBtn");
        const dropdown = document.getElementById("hDropdown");
        if (dropdown && dropdown.classList.contains("open")) {
          if (!btn.contains(e.target) && !dropdown.contains(e.target)) {
            closeHeaderMenu();
          }
        }
      });
    </script>
  </body>
</html>
