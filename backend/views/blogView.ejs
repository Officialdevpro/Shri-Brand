  <script>
    const API_BASE    = '/api/v1/blogs/<%= blogId %>';
    const FETCH_TIMEOUT = 10000;
    // Real API endpoint (no id/slug appended — the base IS the full URL)
    const DIRECT_URL  = API_BASE;

    
    const CAT_META = {
      'traditions':    { label: 'Traditions',    icon: 'fa-hands-praying' },
      'artisan-crafts':{ label: 'Artisan Crafts', icon: 'fa-palette' },
      'festivals':     { label: 'Festivals',      icon: 'fa-star-and-crescent' },
      'wellness':      { label: 'Wellness',       icon: 'fa-leaf' },
      'community':     { label: 'Community',      icon: 'fa-people-group' },
      'sacred-recipes':{ label: 'Sacred Recipes', icon: 'fa-bowl-rice' },
    };

    async function apiFetch(url) {
      const ctrl  = new AbortController();
      const timer = setTimeout(() => ctrl.abort(), FETCH_TIMEOUT);
      try {
        const resp = await fetch(url, { signal: ctrl.signal });
        clearTimeout(timer);
        const body = await resp.json().catch(() => ({}));
        if (!resp.ok) throw new Error(body.message || `HTTP ${resp.status}`);
        return body;
      } catch (err) {
        clearTimeout(timer);
        if (err.name === 'AbortError') throw new Error('Request timed out. Check your connection.');
        throw err;
      }
    }

    // Helper: get content — API sends html for paragraphs, text for headings
    function blockContent(block) {
      // html field may be populated (paragraphs) or empty string (headings use text)
      return (block.html && block.html.trim()) ? block.html : (block.text || '');
    }

    function renderBlock(block) {
      switch (block.type) {
        case 'paragraph': {
          const el = document.createElement('p');
          el.innerHTML = blockContent(block);
          return el;
        }
        case 'heading': {
          const lvl = Math.min(Math.max(block.level || 2, 1), 3);
          const el  = document.createElement(`h${lvl}`);
          // Headings from API use text field; innerHTML to preserve any emoji
          el.innerHTML = block.text || block.html || '';
          return el;
        }
        case 'blockquote': {
          const bq = document.createElement('blockquote');
          const p  = document.createElement('p');
          p.innerHTML = blockContent(block);
          bq.appendChild(p);
          return bq;
        }
        case 'pullquote': {
          const wrap  = document.createElement('div');
          wrap.className = 'block-pullquote';
          const inner = document.createElement('div');
          inner.className = 'block-pullquote-inner';
          const p = document.createElement('p');
          p.innerHTML = blockContent(block);
          inner.appendChild(p);
          wrap.appendChild(inner);
          return wrap;
        }
        case 'idea': {
          const wrap = document.createElement('div');
          wrap.className = 'block-idea';
          wrap.setAttribute('role', 'note');
          wrap.innerHTML = `
            <div class="block-idea-icon" aria-hidden="true">💡</div>
            <div class="block-idea-body">
              <div class="block-idea-label">Insight</div>
              <p>${blockContent(block)}</p>
            </div>`;
          return wrap;
        }
        case 'warning': {
          const wrap = document.createElement('div');
          wrap.className = 'block-warning';
          wrap.setAttribute('role', 'alert');
          wrap.innerHTML = `
            <div class="block-warning-icon" aria-hidden="true"><i class="fas fa-exclamation-triangle"></i></div>
            <div class="block-warning-body">
              <div class="block-warning-label">Important</div>
              <p>${blockContent(block)}</p>
            </div>`;
          return wrap;
        }
        case 'info': {
          const wrap = document.createElement('div');
          wrap.className = 'block-info';
          wrap.setAttribute('role', 'note');
          wrap.innerHTML = `
            <div class="block-info-icon" aria-hidden="true"><i class="fas fa-circle-info"></i></div>
            <div class="block-info-body">
              <div class="block-info-label">Did you know</div>
              <p>${blockContent(block)}</p>
            </div>`;
          return wrap;
        }
        case 'image': {
          if (!block.url) return null;
          const fig = document.createElement('figure');
          fig.className = 'block-figure';
          const img = document.createElement('img');
          img.src = block.url; img.alt = block.alt || block.caption || '';
          img.loading = 'lazy'; img.decoding = 'async';
          img.style.opacity = '0'; img.style.transition = 'opacity .5s ease';
          img.onload = () => { img.style.opacity = '1'; };
          fig.appendChild(img);
          if (block.caption) {
            const cap = document.createElement('figcaption');
            cap.textContent = block.caption;
            fig.appendChild(cap);
          }
          return fig;
        }
        case 'divider': {
          const style = block.style || 'plain';
          const wrap  = document.createElement('div');
          wrap.className = `block-divider d-${style}`;
          wrap.setAttribute('aria-hidden', 'true');
          if (style === 'diamond') {
            wrap.innerHTML = `<div class="d-line"></div><span class="d-gem">✦ ◆ ✦</span><div class="d-line"></div>`;
          } else if (style === 'flame') {
            wrap.innerHTML = `<div class="d-line"></div><span class="d-gem"><i class="fas fa-fire-flame-curved"></i></span><div class="d-line"></div>`;
          } else if (style === 'stars') {
            wrap.textContent = '✦   ✦   ✦';
          } else if (style === 'wave') {
            wrap.innerHTML = `<svg viewBox="0 0 400 14" xmlns="http://www.w3.org/2000/svg">
              <path d="M0,7 C50,0 100,14 150,7 C200,0 250,14 300,7 C350,0 380,12 400,7"
                stroke="#d4a520" stroke-width="1.5" fill="none" opacity=".6"/>
            </svg>`;
          }
          return wrap;
        }
        case 'list': {
          const tag  = block.ordered ? 'ol' : 'ul';
          const list = document.createElement(tag);
          (block.items || []).forEach(item => {
            const li = document.createElement('li');
            li.textContent = item;
            list.appendChild(li);
          });
          return list;
        }
        case 'code': {
          const lang = block.language || '';
          const wrap = document.createElement('div');
          wrap.className = 'block-code';
          wrap.innerHTML = `
            <div class="block-code-header" aria-hidden="true">
              <div class="code-dot"></div><div class="code-dot"></div><div class="code-dot"></div>
              <span class="code-lang-label">${escHtml(lang) || 'code'}</span>
            </div>
            <pre><code>${escHtml(block.text || '')}</code></pre>`;
          return wrap;
        }
        default: return null;
      }
    }

    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.06, rootMargin: '0px 0px -40px 0px' });

    function populatePage(post) {
      document.title = `${post.title} — Sacred Flame`;

      const crumb = document.getElementById('navCrumb');
      crumb.textContent = post.title.length > 42 ? post.title.slice(0, 42) + '…' : post.title;

      const cat  = post.category || '';
      const meta = CAT_META[cat] || { label: cat || 'Journal', icon: 'fa-seedling' };
      const catEl = document.getElementById('heroCategory');
      catEl.innerHTML = `<i class="fas ${meta.icon}" aria-hidden="true"></i><span>${meta.label}</span>`;

      document.getElementById('heroTitle').textContent    = post.title || '';
      document.getElementById('heroSubtitle').textContent = post.subtitle || '';

      const coverWrap = document.getElementById('heroCoverWrap');
      const cover     = document.getElementById('heroCover');
      if (post.coverImage && post.coverImage.url) {
        cover.src = post.coverImage.url;
        cover.alt = post.coverImage.alt || post.title;
        coverWrap.classList.add('has-image');
        cover.addEventListener('load',  () => cover.classList.add('loaded'));
        cover.addEventListener('error', () => { coverWrap.classList.remove('has-image'); });
      }

      const dateStr = post.publishDate
        ? new Date(post.publishDate).toLocaleDateString('en-IN', { day:'numeric', month:'long', year:'numeric' })
        : (post.createdAt ? new Date(post.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'long', year:'numeric' }) : '');

      document.getElementById('heroAuthor').textContent   = post.author  || 'Sacred Flame';
      document.getElementById('heroDate').textContent     = dateStr       || '—';
      document.getElementById('heroReadTime').textContent = post.readTime || '—';
      const wc = post.stats && post.stats.wordCount ? post.stats.wordCount : 0;
      document.getElementById('heroWords').textContent = wc ? `${wc} words` : '—';

      const heroTagsEl = document.getElementById('heroTags');
      heroTagsEl.innerHTML = '';
      (post.tags || []).forEach(t => {
        const span = document.createElement('span');
        span.className = 'hero-tag'; span.textContent = t; span.setAttribute('role','listitem');
        heroTagsEl.appendChild(span);
      });

      const initial = (post.author || 'S')[0].toUpperCase();
      document.getElementById('footerAvatarLetter').textContent  = initial;
      document.getElementById('footerAuthorName').textContent    = post.author || 'Sacred Flame';

      // Stats tags cell
      const statTagsList = document.getElementById('statTagsList');
      statTagsList.innerHTML = '';
      (post.tags || []).forEach(t => {
        const span = document.createElement('span');
        span.className = 'stat-tag'; span.textContent = t; span.setAttribute('role','listitem');
        statTagsList.appendChild(span);
      });

      document.getElementById('footerDate').textContent     = dateStr || '—';
      document.getElementById('footerReadTime').textContent = post.readTime || '—';

     

      const stats = post.stats || {};
      
    
     
      

      const body = document.getElementById('articleBody');
      body.innerHTML = '';
      (post.blocks || []).forEach((block, idx) => {
        const el = renderBlock(block);
        if (!el) return;
        el.style.transitionDelay = Math.min(idx, 10) * 0.06 + 's';
        body.appendChild(el);
        revealObserver.observe(el);
      });

      setupReadingProgress();
    }

    function setupReadingProgress() {
      const updateProgress = () => {
        const scrollTop = window.scrollY;
        const docH      = document.documentElement.scrollHeight - window.innerHeight;
        const pct       = docH > 0 ? Math.min(100, Math.round(scrollTop / docH * 100)) : 0;
        document.getElementById('readProgress').style.width = pct + '%';
        const fab = document.getElementById('fabBack');
        if (scrollTop > 300) fab.classList.add('visible');
        else fab.classList.remove('visible');
      };
      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    }

    function shareArticle() {
      if (navigator.share) navigator.share({ title: document.title, url: location.href }).catch(() => {});
      else copyLink();
    }
    function copyLink() {
      navigator.clipboard.writeText(location.href).then(() => showToast('Link copied!')).catch(() => showToast('Could not copy link'));
    }
    function shareTwitter() {
      window.open(`https://twitter.com/intent/tweet?url=${encodeURIComponent(location.href)}&text=${encodeURIComponent(document.title)}`, '_blank', 'noopener');
    }
    function shareWhatsApp() {
      window.open(`https://wa.me/?text=${encodeURIComponent(document.title + ' ' + location.href)}`, '_blank', 'noopener');
    }

    let _toastTimer;
    function showToast(msg) {
      let t = document.getElementById('_toast');
      if (!t) {
        t = document.createElement('div');
        t.id = '_toast';
        Object.assign(t.style, {
          position: 'fixed', bottom: '80px', left: '50%', transform: 'translateX(-50%)',
          background: '#1c0d0d', color: 'rgba(255,255,255,.9)',
          border: '1px solid rgba(255,196,6,.3)', borderTop: '2px solid #ffc406',
          padding: '9px 22px', borderRadius: '999px',
          fontFamily: "'Poppins', sans-serif", fontSize: '12px', fontWeight: '600',
          letterSpacing: '.1em', textTransform: 'uppercase',
          boxShadow: '0 6px 24px rgba(127,4,3,.3)',
          zIndex: '999', whiteSpace: 'nowrap',
          transition: 'opacity .25s ease', opacity: '0', pointerEvents: 'none'
        });
        document.body.appendChild(t);
      }
      t.textContent = msg; t.style.opacity = '1';
      clearTimeout(_toastTimer);
      _toastTimer = setTimeout(() => { t.style.opacity = '0'; }, 2200);
    }

    function escHtml(str) {
      return (str || '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#x27;'}[c]));
    }

    function showLoading() {
      document.getElementById('loadingScreen').classList.remove('hidden');
      document.getElementById('articleWrap').classList.remove('visible');
      document.getElementById('errorState').classList.remove('visible');
    }
    function showArticle() {
      document.getElementById('loadingScreen').classList.add('hidden');
      document.getElementById('articleWrap').classList.add('visible');
      document.getElementById('errorState').classList.remove('visible');
    }
    function showError(msg) {
      document.getElementById('loadingScreen').classList.add('hidden');
      document.getElementById('articleWrap').classList.remove('visible');
      const errState = document.getElementById('errorState');
      errState.classList.add('visible');
      document.getElementById('errMsg').textContent = msg || 'This article could not be loaded.';
    }

    async function loadPost() {
      showLoading();
      try {
        const data = await apiFetch(API_BASE);
        // Support both response shapes: { data: { post } } or { data: { blog } } or { data: {...} }
        const post = (data && data.data)
          ? (data.data.post || data.data.blog || data.data)
          : data;
        if (!post || !post.title) throw new Error('Post not found or invalid response.');
        populatePage(post);
        initEngagement(post);
        showArticle();
      } catch (err) {
        console.error('[Sacred Flame] API error:', err);
        showError(err.message || 'Could not load this article. Please try again.');
      }
    }

    async function loadDemoPost() {
      const demo = {
        title: "The Living Flame: Sacred Traditions of Agarbatti Craft",
        subtitle: "How artisans across Tamil Nadu preserve a millennia-old practice that bridges the material and the divine through hand-rolled incense.",
        category: "artisan-crafts",
        author: "Priya Sharma",
        publishDate: new Date().toISOString(),
        readTime: "7 min read",
        tags: ["Tamil Nadu", "Heritage", "Incense", "Artisan", "Sacred"],
        coverImage: {
          url: "https://images.unsplash.com/photo-1604480132736-44c188fe4d20?w=1400&q=85",
          alt: "Artisan rolling incense sticks"
        },
        stats: { wordCount: 1540, blockCount: 22, imageCount: 2 },
        blocks: [
          { id:'b1', type:'paragraph', html:'In the narrow <strong>gullies of Kanchipuram</strong>, before the sun has fully risen, Meenakshi Ammal begins her day the same way her grandmother did — with damp hands pressed gently around a bamboo sliver, rolling <em>agarbatti</em> with the muscle memory of fifty years.' },
          { id:'b2', type:'paragraph', html:'The scent that rises from her work — a blend of sandalwood dust, charcoal, and the resin of Halmaddi — is not merely fragrance. It is a language. A signal to the divine that presence has been acknowledged, that worship has begun.' },
          { id:'b3', type:'heading', level:2, text:'Roots Older Than Memory' },
          { id:'b4', type:'paragraph', html:'Incense craft in South India predates recorded history. Vedic texts reference <em>dhoop</em> and fragrant smoke as essential components of yajna — fire ceremonies meant to carry human intention skyward. Over centuries, the practice diversified into regional traditions, each with its own signature blends, rituals, and family secrets.' },
          { id:'b5', type:'blockquote', text:'When I roll agarbatti, I am not making a product. I am making a prayer. Every stick that leaves my hands carries a little of my intention with it.' },
          { id:'b6', type:'image', url:'https://images.unsplash.com/photo-1599598425947-5202edd56fdf?w=1000&q=80', caption:'Morning light through the workshop — Kanchipuram, Tamil Nadu', alt:'Incense sticks drying in morning light' },
          { id:'b7', type:'heading', level:2, text:'The Alchemy of Ingredients' },
          { id:'b8', type:'paragraph', html:'A master incense-maker is first a herbalist. The finest agarbatti requires an intimate knowledge of botanical properties — which woods burn cool and long, which resins carry scent without acrid bite, how moisture content affects both the roll and the burn.' },
          { id:'b9', type:'idea', text:'Traditional agarbatti formulas were family heirlooms, passed down orally and never written. Some families today still guard three-generation-old recipes, fearing that written documentation invites imitation.' },
          { id:'b10', type:'heading', level:3, text:'Core Ingredients' },
          { id:'b11', type:'list', ordered:false, items:['Sandalwood powder (Santalum album)', 'Jigat — a binding agent from Machilus macrantha bark', 'Halmaddi — a hygroscopic resin that keeps the stick pliable', 'Charcoal dust for even combustion', 'Essential oils: jasmine, rose, patchouli, vetivert'] },
          { id:'b12', type:'heading', level:2, text:'The Rolling Ritual' },
          { id:'b13', type:'paragraph', html:'The actual rolling takes place on a flat wooden board called a <em>phalak</em>. The artisan spreads a finger-width line of damp paste along a bamboo core, then uses the heel of the palm to roll it with a single, fluid forward motion. The resulting shape — slightly tapered at the tip, heavier at the base — is the result of years of practice that no machine has ever convincingly replicated.' },
          { id:'b14', type:'pullquote', text:'There is a silence in hand-rolling that machines cannot manufacture. Each stick is different, and that difference is alive.' },
          { id:'b15', type:'warning', text:'Synthetic fragrances added to low-quality incense can release harmful VOCs when burned indoors. Always choose natural-ingredient products and ensure adequate ventilation during use.' },
          { id:'b16', type:'heading', level:2, text:'Preservation in the Modern Age' },
          { id:'b17', type:'paragraph', html:'The craft faces familiar pressures: machine-made alternatives, younger generations drawn to urban opportunities, and the rising cost of quality raw materials. Yet there is also renewed interest — a global movement toward natural, artisan goods that has found fertile ground in traditional incense.' },
          { id:'b18', type:'info', text:'The Geographical Indication (GI) tag for Bangalore Agarbathi, granted in 2019, was a landmark moment — offering legal protection for traditional craft practices and helping artisans command fair prices in competitive markets.' },
          { id:'b19', type:'image', url:'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1000&q=80', caption:'Bundles of hand-rolled agarbatti ready for drying', alt:'Bundles of incense sticks' },
          { id:'b20', type:'heading', level:2, text:'The Sacred Smoke Carries On' },
          { id:'b21', type:'paragraph', html:'In Meenakshi Ammal\'s workshop, a granddaughter watches — not reluctantly, but with genuine curiosity. She studies in Chennai during the week, returns on weekends. She is learning the rolls, the pastes, the names of things. The tradition, it seems, is choosing to continue through her.' },
          { id:'b22', type:'divider', style:'diamond' },
          { id:'b23', type:'paragraph', html:'The flame that rises from a burning agarbatti lasts only minutes. But the craft that shaped the stick, the hands that rolled it, the knowledge encoded in the blend — those are things that can endure for generations. In Kanchipuram\'s workshops, they still do.' },
          { id:'b24', type:'divider', style:'stars' },
          { id:'b25', type:'code', language:'json', text:'{\n  "traditionalBlend": {\n    "sandalwood": "40%",\n    "jigat":      "20%",\n    "halmaddi":   "15%",\n    "charcoal":   "15%",\n    "fragrance":  "10%"\n  },\n  "burnTime":   "45 minutes",\n  "origins":    "Kanchipuram, Tamil Nadu"\n}' },
        ]
      };
      await new Promise(r => setTimeout(r, 700));
      populatePage(demo);
      initEngagement(demo);
      showArticle();
    }

    document.addEventListener('DOMContentLoaded', loadPost);

    // ── CURRENT POST ID (set after load) ─────────────────────────
    let currentPostId = null;
    // Derive from API_BASE (last path segment)
    const _idMatch = API_BASE.match(/\/([a-f0-9]{24})$/i);
    if (_idMatch) currentPostId = _idMatch[1];

    // ── USER AUTH STATE (reads cookie/localStorage — adjust to your auth setup) ──
    function getAuthToken() {
      return document.cookie.match(/(?:^|;\s*)jwt=([^;]+)/)?.[1] ||
             localStorage.getItem('token') || null;
    }
    function isLoggedIn() { return !!getAuthToken(); }

    function initAuthUI() {
      if (isLoggedIn()) {
        document.getElementById('commentFormWrap').style.display = 'block';
        document.getElementById('commentLoginPrompt').style.display = 'none';
      } else {
        document.getElementById('commentFormWrap').style.display = 'none';
        document.getElementById('commentLoginPrompt').style.display = 'flex';
      }
    }

    // ── REACTIONS ─────────────────────────────────────────────────
    let reactionState = { love: false, read: false };

    async function loadReactions(postId) {
      try {
        const headers = {};
        const tok = getAuthToken();
        if (tok) headers['Authorization'] = `Bearer ${tok}`;
        const res = await fetch(`${API_BASE.replace(/\/[^/]+$/, '')}/${postId}/reactions`, { headers });
        if (!res.ok) return;
        const data = await res.json();
        const counts = data.data?.reactionCounts || data.reactionCounts || {};
        document.getElementById('countLove').textContent = counts.love ?? 0;
        document.getElementById('countRead').textContent = counts.read ?? 0;
        // user's own reaction
        const mine = data.data?.userReaction || data.userReaction || null;
        if (mine === 'love') { reactionState.love = true; document.getElementById('btnLove').classList.add('active-love'); }
        if (mine === 'read') { reactionState.read = true; document.getElementById('btnRead').classList.add('active-read'); }
      } catch(e) { /* silent */ }
    }

    async function toggleReaction(type) {
      if (!currentPostId) return;
      const btn = document.getElementById(type === 'love' ? 'btnLove' : 'btnRead');
      const countEl = document.getElementById(type === 'love' ? 'countLove' : 'countRead');
      const wasActive = reactionState[type];
      // Optimistic UI
      reactionState[type] = !wasActive;
      btn.classList.toggle(type === 'love' ? 'active-love' : 'active-read', !wasActive);
      countEl.textContent = parseInt(countEl.textContent) + (wasActive ? -1 : 1);
      try {
        const headers = { 'Content-Type': 'application/json' };
        const tok = getAuthToken();
        if (tok) headers['Authorization'] = `Bearer ${tok}`;
        const res = await fetch(
          `${API_BASE.replace(/\/[^/]+$/, '')}/${currentPostId}/reactions`,
          { method: 'POST', headers, body: JSON.stringify({ type }) }
        );
        if (!res.ok) throw new Error();
        const data = await res.json();
        const counts = data.data?.reactionCounts || data.reactionCounts || {};
        if (counts.love !== undefined) document.getElementById('countLove').textContent = counts.love;
        if (counts.read !== undefined) document.getElementById('countRead').textContent = counts.read;
      } catch(e) {
        // Revert on error
        reactionState[type] = wasActive;
        btn.classList.toggle(type === 'love' ? 'active-love' : 'active-read', wasActive);
        countEl.textContent = parseInt(countEl.textContent) + (wasActive ? 1 : -1);
      }
    }

    // ── VIEW COUNT ────────────────────────────────────────────────
    function setViewCount(post) {
      document.getElementById('viewCount').textContent = post.viewCount ?? 0;
    }

    // ── COMMENTS ─────────────────────────────────────────────────
    let allComments = [];

    async function loadComments(postId) {
      const list = document.getElementById('commentsList');
      list.innerHTML = '<div class="comments-loading"><i class="fas fa-spinner"></i> Loading comments…</div>';
      try {
        const res = await fetch(`${API_BASE.replace(/\/[^/]+$/, '')}/${postId}/comments`);
        const data = await res.json();
        allComments = data.data?.comments || data.comments || [];
        renderComments();
      } catch(e) {
        list.innerHTML = '<div class="comments-empty"><i class="fas fa-circle-exclamation"></i><p>Could not load comments.</p></div>';
      }
    }

    function renderComments() {
      const sort = document.getElementById('commentSort').value;
      let sorted = [...allComments].filter(c => !c.isHidden);
      sorted.sort((a,b) => sort === 'oldest'
        ? new Date(a.createdAt) - new Date(b.createdAt)
        : new Date(b.createdAt) - new Date(a.createdAt));

      const count = sorted.length;
      document.getElementById('commentsBadge').textContent = count;
      document.getElementById('commentCountJump').textContent = count;

      const list = document.getElementById('commentsList');
      if (!count) {
        list.innerHTML = '<div class="comments-empty"><i class="fas fa-comments"></i><p>No comments yet. Be the first to share your thoughts!</p></div>';
        return;
      }
      list.innerHTML = '';
      sorted.forEach((c, i) => {
        const el = buildCommentEl(c, i);
        list.appendChild(el);
      });
    }

    function buildCommentEl(c, i) {
      const wrap = document.createElement('div');
      wrap.className = 'comment-item';
      wrap.style.animationDelay = `${i * 0.04}s`;

      const authorName = c.author?.name || c.author?.firstName
        ? (c.author.firstName ? `${c.author.firstName} ${c.author.lastName || ''}`.trim() : c.author.name)
        : (typeof c.author === 'string' ? c.author : 'Anonymous');
      const initial = (authorName || 'A')[0].toUpperCase();
      const dateStr = c.createdAt
        ? new Date(c.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' })
        : '';

      const heartedBadge = c.adminHearted
        ? `<span class="comment-hearted-badge"><i class="fas fa-heart"></i> Hearted</span>` : '';

      const adminReplyHtml = c.adminReply?.body ? `
        <div class="admin-reply">
          <div class="admin-reply-header">
            <span class="admin-reply-badge"><i class="fas fa-crown"></i> Sacred Flame</span>
            <span class="admin-reply-date">${c.adminReply.repliedAt ? new Date(c.adminReply.repliedAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) : ''}</span>
          </div>
          <div class="admin-reply-body">${escHtml(c.adminReply.body)}</div>
        </div>` : '';

      wrap.innerHTML = `
        <div class="comment-top">
          <div class="comment-avatar">${initial}</div>
          <div class="comment-meta">
            <div class="comment-author-row">
              <span class="comment-author-name">${escHtml(authorName)}</span>
              <span class="comment-date">${dateStr}</span>
              ${heartedBadge}
            </div>
            <div class="comment-body">${escHtml(c.body)}</div>
          </div>
        </div>
        ${adminReplyHtml}`;
      return wrap;
    }

    async function submitComment() {
      if (!currentPostId) return;
      const input = document.getElementById('commentInput');
      const body = input.value.trim();
      if (!body) { input.focus(); return; }
      const btn = document.getElementById('commentSubmitBtn');
      btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Posting…';
      try {
        const tok = getAuthToken();
        const res = await fetch(`${API_BASE.replace(/\/[^/]+$/, '')}/${currentPostId}/comments`, {
          method: 'POST',
          headers: { 'Content-Type':'application/json', 'Authorization': tok ? `Bearer ${tok}` : '' },
          body: JSON.stringify({ body })
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.message || 'Failed to post');
        input.value = '';
        // Add optimistically
        const newComment = data.data?.comment || { body, createdAt: new Date().toISOString(), author: 'You' };
        allComments.unshift(newComment);
        renderComments();
        showToast('Comment posted!');
      } catch(e) {
        showToast(e.message || 'Could not post comment');
      } finally {
        btn.disabled = false; btn.innerHTML = '<i class="fas fa-paper-plane"></i> Post Comment';
      }
    }

    // Load reactions/views/comments after page is populated
    function initEngagement(post) {
      currentPostId = post._id || currentPostId;
      setViewCount(post);
      document.getElementById('countLove').textContent = post.reactionCounts?.love ?? 0;
      document.getElementById('countRead').textContent = post.reactionCounts?.read ?? 0;
      initAuthUI();
      if (currentPostId) {
        loadReactions(currentPostId);
        loadComments(currentPostId);
      }
    }
  </script>
</body>
</html>